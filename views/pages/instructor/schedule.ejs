@media (max-width:420px) {
  .gcal-wrap { padding: 0.65rem; pointer-events: auto !important; }
  .gcal-top { gap: 0.3rem; pointer-events: auto !important; }
  .gcal-title { font-size: 0.85rem; pointer-events: auto !important; }
  .gcal-tz { font-size: 0.65rem; pointer-events: auto !important; }
  .mini-head { margin-bottom: 0.4rem; pointer-events: auto !important; }
  .mini-month { font-size: 0.75rem; pointer-events: auto !important; }
  .mini-nav button { width: 22px; height: 22px; font-size: 0.7rem; pointer-events: auto !important; }
  .mini-grid { gap: 1px; pointer-events: auto !important; }
  .mini-day { height: 20px; font-size: 0.65rem; pointer-events: auto !important; }
  .week-strip { display: flex !important; flex-wrap: nowrap !important; width: fit-content !important; gap: 0.2rem !important; pointer-events: auto !important; padding: 0.3rem 0; }
