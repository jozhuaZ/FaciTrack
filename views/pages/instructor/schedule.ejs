}
document.getElementById('slotViewEditBtn').addEventListener('click',function(){
  if(slotViewIdx<0) return;
  const idx=slotViewIdx;
  closeSlotView();
  editSlot(idx);
});

/* -- Edit slot -- */
function editSlot(idx){
  const slot=slots[idx];
  if(!slot) return;
  document.getElementById('slotDay').value=slot.day;
  document.getElementById('slotEditIdx').value=idx;
  document.getElementById('slotMaxCapacity').value=slot.maxCapacity||3;
  document.getElementById('slotModalTitle').textContent='Edit Slot - '+slot.day;
  
  // Find the date for this day of the week in the current week view
  const dayIndex = DAYS.indexOf(slot.day);
  let slotDate = null;
  if (dayIndex >= 0) {
    // Calculate the date based on the current selectedDate
    const currentDayIndex = selectedDate.getDay();
    const dayDiff = dayIndex - currentDayIndex;
    slotDate = new Date(selectedDate);
    slotDate.setDate(selectedDate.getDate() + dayDiff);
  }
  
  if(slotDate) document.getElementById('slotModal').dataset.date=slotDate.getTime();
  else delete document.getElementById('slotModal').dataset.date;
  document.getElementById('slotConflictWarn').classList.remove('show');
  initializeTimePicker(slot.day, slotDate, slot);
  document.getElementById('slotModal').classList.add('show');
}

/* -- Toggle status -- */
function toggleSlotStatus(idx){
  const slot=slots[idx];
  if(!slot) return;
  slot.status=slot.status==='open'?'closed':'open';
  saveSlots();
  renderWeekStrip();
  refreshDayPanel();
  showToast('success','Updated','Slot '+(slot.status==='open'?'opened':'closed')+' for '+slot.day+' '+slot.timeStart);
}

/* -- Delete slot -- */
function deleteSlot(idx){
  const slot=slots[idx];
  if(!slot) return;
  if(!confirm('Delete slot on '+slot.day+' ('+slot.timeStart+' \u2013 '+slot.timeEnd+')?')) return;
  slots.splice(idx,1);
  saveSlots();
  renderWeekStrip();
  refreshDayPanel();
}

/* -- Open Add modal -- */
function openAddModal(day, date){
  document.getElementById('slotEditIdx').value=-1;
  document.getElementById('slotConflictWarn').classList.remove('show');
  document.getElementById('slotDay').value=day||'';
  document.getElementById('slotModalTitle').textContent='Add Slot'+(day?' - '+day:'');
  if(date) document.getElementById('slotModal').dataset.date=date.getTime();
  else delete document.getElementById('slotModal').dataset.date;
  document.getElementById('slotMaxCapacity').value='3';
  initializeTimePicker(day, date, null);
  document.getElementById('slotModal').classList.add('show');
}

/* -- Conflict detection (removed - now handled by time picker) -- */
function updatePreview(){
  // This function is no longer needed - validation happens in validateTimeSelection()
}

/* -- Save -- */
function saveSlots(){
  fetch('/instructor/schedule/save',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({slots:slots})
  }).then(function(r){return r.json();}).then(function(data){
    if(data.success) showToast('success','Saved','Schedule updated successfully');
    else showToast('error','Error',data.error||'Failed to save');
  }).catch(function(){ showToast('error','Error','Network error'); });
  // Auto-refresh the day panel if it's open
  refreshDayPanel();
}

/* -- Confirm (Add / Edit) -- */
document.getElementById('confirmSlot').addEventListener('click',function(){
  // Check if button is disabled
  if(this.disabled) {
    return;
  }
  
  const day=document.getElementById('slotDay').value;
  const timeStart=formatTimeFromState('start');
  const timeEnd=formatTimeFromState('end');
  const maxCapacity=Math.max(1,Math.min(10,parseInt(document.getElementById('slotMaxCapacity').value,10)||1));
  const editIdx=parseInt(document.getElementById('slotEditIdx').value,10);
  // Status: preserve existing when editing, default to 'open' for new slots
  const status = editIdx >= 0 ? (slots[editIdx].status || 'open') : 'open';

  if(!day||!timeStart||!timeEnd){ showToast('error','Required','Please fill in all fields'); return; }

  const startMins=getTimeInMinutes('start');
  const endMins=getTimeInMinutes('end');
  
  const modalDateMs=document.getElementById('slotModal').dataset.date;
  if(modalDateMs && editIdx<0 && isPastDate(new Date(parseInt(modalDateMs)))){
    // Allow past dates if instructor chooses them, do not block.
  }

  if(editIdx>=0){
    const existing=slots[editIdx];
    slots[editIdx]=Object.assign({},existing,{day:day,timeStart:timeStart,timeEnd:timeEnd,maxCapacity:maxCapacity,status:status});
    showToast('success','Updated','Slot updated for '+day);
  } else {
    slots.push({day:day,timeStart:timeStart,timeEnd:timeEnd,maxCapacity:maxCapacity,bookedCount:0,status:status});
    showToast('success','Added','New slot added for '+day);
  }
  saveSlots();
  renderWeekStrip();
  refreshDayPanel();
  document.getElementById('slotModal').classList.remove('show');
});

initTimePickerDrag();

/* -- Stepper wiring -- */
(function() {
  const minusBtn = document.getElementById('stepperMinus');
  const plusBtn  = document.getElementById('stepperPlus');
  const capInput = document.getElementById('slotMaxCapacity');
  function updateStepper(delta) {
    let val = parseInt(capInput.value, 10) || 1;
    val = Math.min(10, Math.max(1, val + delta));
    capInput.value = val;
    validateTimeSelection();
  }
  if (minusBtn) minusBtn.addEventListener('click', function() { updateStepper(-1); });
  if (plusBtn)  plusBtn.addEventListener('click',  function() { updateStepper(+1); });
})();

