      '<span>No slots for '+esc(activePanelDay)+'.</span>'+
      '<span style="font-size:.75rem">Click <strong>+ Add Slot</strong> on the day card to add one.</span>';
    body.appendChild(empty);
    return;
  }
  daySlots.forEach(function(s){
    const gIdx   = slots.indexOf(s);
    const cap    = Math.max(1, parseInt(s.maxCapacity,10)||1);
    const booked = parseInt(s.bookedCount,10)||0;
    const isFull = booked >= cap;
    const statusKey   = s.status==='closed' ? 'closed' : (isFull ? 'full' : 'open');
    const statusLabel = statusKey.charAt(0).toUpperCase()+statusKey.slice(1);
    const group = document.createElement('div');
    group.className = 'dsp-slot-group';
    const header = document.createElement('div');
    header.className = 'dsp-slot-group-header';
    header.innerHTML =
      '<span class="dsp-slot-range">'+esc(s.timeStart)+' \u2013 '+esc(s.timeEnd)+'</span>'+
      '<div style="display:flex;align-items:center;gap:.5rem">'+
        (statusKey!=='open' ? '<span class="dsp-slot-badge '+statusKey+'">'+statusLabel+'</span>' : '')+
        '<button class="dsp-slot-action-btn" onclick="toggleSlotStatus('+gIdx+')" title="Toggle Open/Closed">'+
          '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">'+(s.status==='closed'?'<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>':'<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/>')+'</svg>'+
        '</button>'+
        '<button class="dsp-slot-action-btn" onclick="editSlot('+gIdx+')" title="Edit">'+
          '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>'+
        '</button>'+
        '<button class="dsp-slot-action-btn delete" onclick="deleteSlot('+gIdx+')" title="Delete">'+
          '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>'+
        '</button>'+
      '</div>';
    group.appendChild(header);
    const grid = document.createElement('div');
    grid.className = 'dsp-subslot-grid';
    splitSlotTimes(s).forEach(function(timeStr, idx){
      const isBooked = idx < booked;
      const card = document.createElement('div');
