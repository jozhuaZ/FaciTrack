  .gcal-top { gap: 0.5rem !important; }
  .gcal-title { font-size: 1rem !important; font-weight: 700 !important; }
  .gcal-tz { font-size: 0.72rem !important; opacity: 0.8; }
  .mini-cal { margin-bottom: 0.8rem; }
  .page-header { margin-bottom: 0.75rem; }
