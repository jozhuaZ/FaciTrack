  // No restrictions: instructor can choose any time freely.
}


function validateTimeSelection() {
  const saveBtn = document.getElementById('confirmSlot');
  const minusBtn = document.getElementById('stepperMinus');
  const plusBtn  = document.getElementById('stepperPlus');
  const capInput = document.getElementById('slotMaxCapacity');
  const cap = Math.max(1, parseInt(capInput ? capInput.value : 1, 10) || 1);

  if (minusBtn) minusBtn.disabled = cap <= 1;
  if (plusBtn)  plusBtn.disabled  = cap >= 10;

  if (saveBtn) {
    saveBtn.disabled = false;
    saveBtn.style.opacity = '1';
    saveBtn.style.cursor = 'pointer';
    saveBtn.title = 'Click to save this slot';
  }
}


function initializeTimePicker(day, date, slot) {
  timePickerState.selectedDay = day;
  timePickerState.selectedDate = date;
  
  // Show date context in modal if available
  const modalTitle = document.getElementById('slotModalTitle');
  if (date && modalTitle) {
    const dateStr = MONTHS[date.getMonth()] + ' ' + date.getDate() + ', ' + date.getFullYear();
    const dayStr = DAYS[date.getDay()];
    modalTitle.textContent = (slot ? 'Edit' : 'Add') + ' Slot - ' + dayStr + ' | ' + dateStr;
  }
  
  if (slot) {
    // Editing existing slot - parse times
    const startParts = slot.timeStart.match(/(\d+):(\d+)\s*(AM|PM)/);
    const endParts = slot.timeEnd.match(/(\d+):(\d+)\s*(AM|PM)/);
    if (startParts) {
      timePickerState.start = {
        hour: parseInt(startParts[1], 10),
        minute: parseInt(startParts[2], 10),
        period: startParts[3]
      };
    }
    if (endParts) {
      timePickerState.end = {
        hour: parseInt(endParts[1], 10),
        minute: parseInt(endParts[2], 10),
        period: endParts[3]
      };
    }
  } else {
    // New slot - set default to 12:00 AM
    const now = new Date();
    const selectedDate = new Date(date);
    
    // If same day, start from current time + 1 minute
    if (normalizeDate(selectedDate).getTime() === normalizeDate(now).getTime()) {
      let currentMinutes = now.getHours() * 60 + now.getMinutes();
      
      // Start from next minute
      let nextMinutes = currentMinutes + 1;
      
      // Calculate hour and minute from total minutes
      let startHour24 = Math.floor(nextMinutes / 60);
      let startMinute = nextMinutes % 60;
      
      // Handle day overflow (if rounded to next day)
      if (startHour24 >= 24) {
        startHour24 = 0;
        startMinute = 0;
      }
      
      // Convert to 12-hour format
      const startPeriod = startHour24 >= 12 ? 'PM' : 'AM';
      let startHour12 = startHour24 % 12;
      if (startHour12 === 0) startHour12 = 12;
      
      // End time is 1 hour after start time
      let endMinutes = nextMinutes + 60;
      let endHour24 = Math.floor(endMinutes / 60);
      let endMinute = endMinutes % 60;
      
      if (endHour24 >= 24) {
        endHour24 = 23;
        endMinute = 59;
      }
      
      const endPeriod = endHour24 >= 12 ? 'PM' : 'AM';
      let endHour12 = endHour24 % 12;
      if (endHour12 === 0) endHour12 = 12;

      timePickerState.start = { hour: startHour12, minute: startMinute, period: startPeriod };
      timePickerState.end = { hour: endHour12, minute: endMinute, period: endPeriod };
    } else {
      // Future day - default to 8:00 AM
      timePickerState.start = { hour: 8, minute: 0, period: 'AM' };
      timePickerState.end = { hour: 9, minute: 0, period: 'AM' };
    }
  }
  
  // Update displays
  updateTimeDisplay('start');
  updateTimeDisplay('end');
  setPeriod('start', timePickerState.start.period);
  setPeriod('end', timePickerState.end.period);
  
  // Validate and update the save button state
  validateTimeSelection();
}

function parseTimeValue(str){
  const parts = str.trim().split(' ');
  let [h,m] = parts[0].split(':').map(Number);
  const p = parts[1];
  if (p==='PM' && h!==12) h+=12;
  if (p==='AM' && h===12) h=0;
  return h*60+m;
}
function formatTimeValue(mins){
  let h=Math.floor(mins/60), m=mins%60;
  const p=h>=12?'PM':'AM';
  if(h>12)h-=12; if(h===0)h=12;
  return h+':'+String(m).padStart(2,'0')+' '+p;
}
function formatTime24(t){
  const parts=t.split(':'), h=parseInt(parts[0],10), m=parts[1];
  const p=h>=12?'PM':'AM', h12=h===0?12:h>12?h-12:h;
  return h12+':'+m+' '+p;
}
function toInputTime(str){
  const parts=str.trim().split(' ');
  let [h,m]=parts[0].split(':').map(Number);
  const p=parts[1];
  if(p==='PM'&&h!==12)h+=12; if(p==='AM'&&h===12)h=0;
  return String(h).padStart(2,'0')+':'+String(m).padStart(2,'0');
}
function splitSlotTimes(slot){
  const start=parseTimeValue(slot.timeStart), end=parseTimeValue(slot.timeEnd);
  const cap=Math.max(1,parseInt(slot.maxCapacity,10)||1);
  const piece=Math.floor((end-start)/cap);
  const res=[];
  for(let i=0;i<cap;i++){
    const s=start+i*piece, e=i===cap-1?end:s+piece;
    res.push(formatTimeValue(s)+' \u2013 '+formatTimeValue(e));
  }
  return res;
}

/* -- Overlap detection -- */
function findConflict(day, startMins, endMins, excludeIdx){
  return slots.findIndex(function(s,i){
    if(i===excludeIdx) return false;
    if(s.day!==day) return false;
    const sS=parseTimeValue(s.timeStart), sE=parseTimeValue(s.timeEnd);
    return startMins<sE && endMins>sS;
  });
}

