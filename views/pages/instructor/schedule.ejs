<script>
let slots = <%- JSON.stringify(consultationSlots || []) %>;
const DAYS      = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const DOW_SHORT = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const MONTHS    = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const today = new Date(); today.setHours(0,0,0,0);
let selectedDate  = new Date(today);
let viewMonthDate = new Date(today.getFullYear(), today.getMonth(), 1);
let slotViewIdx   = -1;

/* -- Helpers -- */
function normalizeDate(d){ const n=new Date(d); n.setHours(0,0,0,0); return n; }
function isPastDate(d){ return normalizeDate(d).getTime() < today.getTime(); }
function esc(v){ return String(v||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

/* -- Custom Time Picker -- */
let timePickerState = {
  start: { hour: 12, minute: 0, period: 'AM' },
  end: { hour: 1, minute: 0, period: 'AM' },
  selectedDay: null,
  selectedDate: null
};

function adjustTime(type, unit, delta) {
  const state = timePickerState[type];
  if (unit === 'hour') {
    state.hour += delta;
    if (state.hour > 12) state.hour = 1;
    if (state.hour < 1) state.hour = 12;
  } else {
    state.minute += delta; // 1-minute increments
    if (state.minute >= 60) state.minute = 0;
    if (state.minute < 0) state.minute = 59;
  }
  updateTimeDisplay(type);

  // Auto-adjust end time to stay 1 hour ahead of start
  if (type === 'start') {
    autoAdjustEndTime();
  }

  validateTimeSelection();
}

let timePickerDragState = null;

function initTimePickerDrag() {
  const wheels = document.querySelectorAll('.time-wheel');
  wheels.forEach(function(el) {
    el.addEventListener('pointerdown', function(event) {
      if (event.button !== 0) return;
      const match = el.id.match(/^(start|end)(Hour|Minute)Wheel$/);
      if (!match) return;
      event.preventDefault();
      timePickerDragState = {
        type: match[1],
        unit: match[2].toLowerCase(),
        startY: event.clientY,
        pointerId: event.pointerId
      };
      el.setPointerCapture(event.pointerId);
    });
    el.addEventListener('wheel', function(event) {
      event.preventDefault();
      const match = el.id.match(/^(start|end)(Hour|Minute)Wheel$/);
      if (!match) return;
      const type = match[1];
      const unit = match[2].toLowerCase();
      const delta = event.deltaY < 0 ? 1 : -1;
      adjustTime(type, unit, delta);
    }, { passive: false });
  });

  document.addEventListener('pointermove', function(event) {
    if (!timePickerDragState || event.pointerId !== timePickerDragState.pointerId) return;
    const deltaY = timePickerDragState.startY - event.clientY;
    const stepSize = 18;
    const stepCount = Math.trunc(deltaY / stepSize);
    if (stepCount !== 0) {
      adjustTime(timePickerDragState.type, timePickerDragState.unit, stepCount);
      timePickerDragState.startY -= stepCount * stepSize;
    }
  });

  document.addEventListener('pointerup', function(event) {
    if (timePickerDragState && event.pointerId === timePickerDragState.pointerId) {
      timePickerDragState = null;
    }
  });
  document.addEventListener('pointercancel', function(event) {
    if (timePickerDragState && event.pointerId === timePickerDragState.pointerId) {
      timePickerDragState = null;
    }
  });
}

function setPeriod(type, period) {
  timePickerState[type].period = period;
  document.getElementById(type+'AM').classList.toggle('active', period === 'AM');
  document.getElementById(type+'PM').classList.toggle('active', period === 'PM');

  // Auto-adjust end time to stay 1 hour ahead of start (only when start changes)
  if (type === 'start') {
    autoAdjustEndTime();
  }

  validateTimeSelection();
}

// Keep end time exactly 1 hour ahead of start time
function autoAdjustEndTime() {
  const s = timePickerState.start;
  // Convert start to 24h minutes
  let startH = s.hour;
  if (s.period === 'PM' && startH !== 12) startH += 12;
  if (s.period === 'AM' && startH === 12) startH = 0;
  let endMins = startH * 60 + s.minute + 60; // +1 hour
  if (endMins >= 24 * 60) endMins -= 24 * 60; // wrap midnight
  // Convert back to 12h
  const endH24 = Math.floor(endMins / 60);
  const endMin = endMins % 60;
  const endPeriod = endH24 >= 12 ? 'PM' : 'AM';
  let endH12 = endH24 % 12;
  if (endH12 === 0) endH12 = 12;
  timePickerState.end = { hour: endH12, minute: endMin, period: endPeriod };
  updateTimeDisplay('end');
  // Update AM/PM buttons directly (avoid calling setPeriod to prevent recursion)
  const amBtn = document.getElementById('endAM');
  const pmBtn = document.getElementById('endPM');
  if (amBtn) amBtn.classList.toggle('active', endPeriod === 'AM');
  if (pmBtn) pmBtn.classList.toggle('active', endPeriod === 'PM');
}

function renderTimeWheel(type, unit) {
  const wheelId = type + (unit === 'hour' ? 'HourWheel' : 'MinuteWheel');
  const el = document.getElementById(wheelId);
  if (!el) return;
  const current = timePickerState[type][unit];
  const values = [];
  if (unit === 'hour') {
    for (let offset = -2; offset <= 2; offset++) {
      let value = current + offset;
      if (value > 12) value -= 12;
      if (value < 1) value += 12;
      values.push(value);
    }
  } else {
    for (let offset = -2; offset <= 2; offset++) {
      let value = current + offset;
      if (value < 0) value += 60;
      if (value >= 60) value -= 60;
      values.push(value);
    }
  }
  el.innerHTML = values.map(function(value, index) {
    return '<div class="wheel-item" data-value="' + value + '">' + String(value).padStart(2, '0') + '</div>';
  }).join('');
}

function updateTimeDisplay(type) {
  renderTimeWheel(type, 'hour');
  renderTimeWheel(type, 'minute');
}

function getTimeInMinutes(type) {
  const state = timePickerState[type];
  let hour = state.hour;
  if (state.period === 'PM' && hour !== 12) hour += 12;
  if (state.period === 'AM' && hour === 12) hour = 0;
  return hour * 60 + state.minute;
}

function formatTimeFromState(type) {
  const state = timePickerState[type];
  return state.hour + ':' + String(state.minute).padStart(2, '0') + ' ' + state.period;
}

function isTimePast(hour, minute, period) {
  if (!timePickerState.selectedDate) return false;
  const now = new Date();
  const selectedDate = new Date(timePickerState.selectedDate);
  
  // Normalize dates to compare only year/month/day (ignore time)
  const selectedDay = normalizeDate(selectedDate).getTime();
  const currentDay = normalizeDate(now).getTime();
  
  // If selected date is in the future, no times are past
  if (selectedDay > currentDay) {
    return false;
  }
  
  // If selected date is in the past, all times are past
  if (selectedDay < currentDay) {
    return true;
  }
  
  // Same day - check actual time with proper 24-hour conversion
  let checkHour = hour;
  if (period === 'PM' && hour !== 12) {
    checkHour = hour + 12; // 1 PM = 13, 2 PM = 14, etc.
  } else if (period === 'AM' && hour === 12) {
    checkHour = 0; // 12 AM = 0 (midnight)
  }
  // If AM and not 12, keep as is (1 AM = 1, 2 AM = 2, etc.)
  
  const checkMinutes = checkHour * 60 + minute;
  const nowMinutes = now.getHours() * 60 + now.getMinutes();
  
  // Time is past if it's less than current time
  return checkMinutes < nowMinutes;
}

function hasConflict(startMins, endMins) {
  if (!timePickerState.selectedDay) return false;
  const editIdx = parseInt(document.getElementById('slotEditIdx').value, 10);
  return findConflict(timePickerState.selectedDay, startMins, endMins, editIdx) >= 0;
}

