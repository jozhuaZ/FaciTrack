  .modal-title { font-size: 0.95rem; }
  .slot-form-label { font-size: 0.75rem; margin-bottom: 0.35rem; }
  .time-picker-wrapper{grid-template-columns:auto auto auto;justify-items:center;padding:.5rem .4rem;gap:.25rem;}
