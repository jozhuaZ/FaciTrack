.slot-form-label{display:block;font-size:.8rem;font-weight:700;color:#374151;margin-bottom:.5rem;letter-spacing:-.01em;text-align:center;}
.slot-form-input,.slot-form-select{width:100%;padding:.65rem .85rem;border:2px solid #e5e7eb;border-radius:10px;font-size:.875rem;transition:all 0.2s ease;background:#fff;}
.slot-form-input:focus,.slot-form-select:focus{outline:none;border-color:#3b82f6;box-shadow:0 0 0 4px rgba(59,130,246,0.1);}
.slot-form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}

/* Modern time picker */
.time-picker-wrapper {
    position: relative;
    display: grid;
    grid-template-columns: auto auto auto auto;
    align-items: center;
    justify-content: center;
    gap: .35rem;
    background: linear-gradient(to bottom, #ffffff, #f9fafb);
    border: 2px solid #e5e7eb;
    border-radius: 10px;
    padding: .65rem .6rem;
    transition: all 0.2s ease;
    width: auto;
    max-width: 340px;
}
.time-picker-wrapper:focus-within {
    border-color: #3b82f6;
    box-shadow: 0 0 0 4px rgba(59,130,246,0.1);
    background: #fff;
}
.time-picker-wrapper.disabled {
    background: #f3f4f6;
    border-color: #e5e7eb;
    opacity: 0.5;
    cursor: not-allowed;
}
.time-segment {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .25rem;
}
.time-arrow {
    display: none;
}
.time-arrow:hover:not(.disabled) {
    background: #3b82f6;
    border-color: #3b82f6;
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 2px 4px rgba(59,130,246,0.3);
}
.time-arrow:active:not(.disabled) {
    transform: translateY(0);
}
.time-arrow.disabled {
    opacity: 0.25;
    cursor: not-allowed;
    pointer-events: none;
    background: #f9fafb;
}
.time-arrow svg {
    width: 13px;
    height: 13px;
}
.time-wheel {
    width: 68px;
    min-width: 66px;
    height: 140px;
    overflow: hidden;
    border: 2px solid #e5e7eb;
    border-radius: 20px;
    background: #fff;
    box-shadow: inset 0 0 0 1px rgba(229,231,235,0.8);
    display: grid;
    grid-template-rows: repeat(5, minmax(0, 1fr));
    position: relative;
    touch-action: none;
    cursor: grab;
}
.time-wheel:active {
    cursor: grabbing;
}
.time-wheel::before {
    content: '';
    position: absolute;
    left: 6px;
    right: 6px;
    top: 50%;
    height: 50px;
    transform: translateY(-50%);
    border-radius: 16px;
    border: 1px solid rgba(59,130,246,0.16);
    background: rgba(255,255,255,0.95);
    pointer-events: none;
}
.time-wheel::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(255,255,255,0.96), rgba(255,255,255,0.55) 18%, rgba(255,255,255,0.55) 82%, rgba(255,255,255,0.96));
    pointer-events: none;
}
.wheel-item {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-size: 1.05rem;
    font-weight: 700;
    color: #111827;
    opacity: 0.7;
    user-select: none;
    transition: color 0.2s ease, opacity 0.2s ease, transform 0.2s ease;
}
.wheel-item:nth-child(3) {
    color: #000000;
    opacity: 1;
    transform: scale(1.08);
}
.wheel-item:nth-child(2),
.wheel-item:nth-child(4) {
    opacity: 0.75;
}
.wheel-item:nth-child(1),
.wheel-item:nth-child(5) {
    opacity: 0.55;
}
.wheel-item.disabled {
    opacity: 0.35;
}
.time-picker-wrapper.disabled .wheel-item {
    color: #9ca3af;
}
.time-separator {
    font-size: 1.4rem;
    font-weight: 700;
    color: #9ca3af;
    margin: 0 .2rem;
}
.time-period {
    display: flex;
    flex-direction: column;
    gap: .35rem;
    margin-left: 0;
    justify-self: center;
}
.period-btn {
    padding: .35rem .7rem;
    font-size: .7rem;
    font-weight: 700;
    border: 2px solid #e5e7eb;
    border-radius: 6px;
    background: #fff;
    color: #6b7280;
    cursor: pointer;
    transition: all 0.2s ease;
    text-transform: uppercase;
    letter-spacing: .03em;
    box-shadow: 0 1px 2px rgba(0,0,0,0.05);
}
.period-btn:hover:not(.disabled) {
    border-color: #3b82f6;
    color: #3b82f6;
    transform: translateY(-1px);
    box-shadow: 0 2px 4px rgba(59,130,246,0.2);
}
.period-btn.active {
    background: linear-gradient(135deg, #3b82f6, #2563eb);
    border-color: #2563eb;
    color: #fff;
    box-shadow: 0 2px 6px rgba(37,99,235,0.3);
}
.period-btn.disabled {
    opacity: 0.25;
    cursor: not-allowed;
    pointer-events: none;
    background: #f9fafb;
}


/* Slot display in week strip */
.w-slots { margin-top: 0.5rem; display: flex; flex-direction: column; gap: 0.35rem; width: 100%; align-items: stretch; }
.w-slot {
    position: relative;
    font-size: .67rem;
    background: linear-gradient(135deg, #1a73e8 0%, #1565c0 100%);
    color: #fff;
    padding: .38rem .5rem .38rem 2.3rem;
    border-radius: 7px;
    text-align: left;
    overflow: hidden;
    transition: all 0.2s ease;
    cursor: default;
    box-shadow: 0 1px 3px rgba(26,115,232,0.15);
    pointer-events: auto;
    -webkit-tap-highlight-color: transparent;
    -webkit-user-select: none;
    user-select: none;
}
.w-slot:hover { transform: translateY(-2px); box-shadow: 0 4px 14px rgba(26,115,232,0.3); }
.w-slot.closed { background: linear-gradient(135deg, #9ca3af 0%, #6b7280 100%); box-shadow: 0 1px 3px rgba(107,114,128,0.15); }
.w-slot.full  { background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%); box-shadow: 0 1px 3px rgba(220,38,38,0.15); }
/* time label inside chip */
.w-slot .slot-label { display:block; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; line-height:1.35; }
/* capacity badge */
.w-slot .slot-cap {
    display: block;
    font-size: .6rem;
    opacity: .85;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.2;
    margin-top: 1px;
}
/* eye / view button — left side */
.w-slot .slot-view-btn {
    position: absolute;
    top: 50%;
    left: 4px;
    transform: translateY(-50%);
    width: 20px;
    height: 20px;
    border: none;
    padding: 0;
    background: rgba(255,255,255,0.2);
    border-radius: 5px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    flex-shrink: 0;
}
.w-slot .slot-view-btn:hover { background: rgba(255,255,255,0.4); transform: translateY(-50%) scale(1.1); }
.w-slot .slot-view-btn svg { width: 12px; height: 12px; }
/* action row — edit + delete, shown on hover */
.w-slot .slot-actions {
    position: absolute;
    top: 3px;
    right: 3px;
    display: flex;
    gap: 3px;
    opacity: 0;
    transition: opacity 0.2s ease;
}
.w-slot:hover .slot-actions { opacity: 1; }
.w-slot .slot-action-btn {
    width: 16px;
    height: 16px;
    background: rgba(255,255,255,0.25);
    border: none;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 9px;
    color: #fff;
    padding: 0;
    transition: all 0.18s ease;
}
.w-slot .slot-action-btn:hover { background: rgba(255,255,255,0.45); transform: scale(1.1); }
.w-slot .slot-action-btn svg { width: 10px; height: 10px; }
/* status toggle pill inside chip */
.slot-status-pill {
    display: inline-block;
