  .mini-day { height: 22px; font-size: 0.68rem; pointer-events: auto !important; }
  .week-strip { display: flex !important; flex-wrap: nowrap !important; width: fit-content !important; gap: 0.25rem !important; pointer-events: auto !important; padding: 0.4rem 0; }
  .week-day { min-width: 78px !important; min-height: 92px !important; padding: 0.5rem 0.35rem !important; flex-shrink: 0 !important; flex-grow: 0 !important; pointer-events: auto !important; touch-action: manipulation !important; user-select: none !important; border-radius: 11px !important; }
