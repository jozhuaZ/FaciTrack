/* -- Mini calendar -- */
function renderMiniCalendar(){
  const year=viewMonthDate.getFullYear(), month=viewMonthDate.getMonth();
  document.getElementById('miniMonthTitle').textContent=MONTHS[month]+' '+year;
  const grid=document.getElementById('miniCalGrid');
  grid.innerHTML='';
  DOW_SHORT.forEach(function(d){
    const el=document.createElement('div'); el.className='mini-dow'; el.textContent=d[0]; grid.appendChild(el);
  });
  const firstDay=new Date(year,month,1), offset=firstDay.getDay(), prevLast=new Date(year,month,0).getDate();
  for(let i=offset-1;i>=0;i--){
    const p=document.createElement('div'); p.className='mini-day other'; p.textContent=prevLast-i; grid.appendChild(p);
  }
  const lastDate=new Date(year,month+1,0).getDate();
  for(let d=1;d<=lastDate;d++){
    const date=new Date(year,month,d), cell=document.createElement('div');
    cell.className='mini-day'; cell.textContent=d;
    if(isPastDate(date)) cell.classList.add('past'); else cell.classList.add('bookable');
    if(normalizeDate(date).getTime()===today.getTime()) cell.classList.add('today');
    if(normalizeDate(date).getTime()===normalizeDate(selectedDate).getTime()) cell.classList.add('selected');
    if(!isPastDate(date)){
      cell.addEventListener('click',function(){ selectedDate=new Date(date); viewMonthDate=new Date(date.getFullYear(), date.getMonth(), 1); renderMiniCalendar(); renderWeekStrip(); });
    }
    grid.appendChild(cell);
  }
  const total=offset+lastDate, rest=(Math.ceil(total/7)*7)-total;
  for(let i=1;i<=rest;i++){
    const n=document.createElement('div'); n.className='mini-day other'; n.textContent=i; grid.appendChild(n);
  }
}

/* -- Week strip -- */
function renderWeekStrip(){
  const strip=document.getElementById('weekStrip'), empty=document.getElementById('weekEmpty');
  strip.innerHTML='';
  const startDate=normalizeDate(selectedDate);
  let hasAvailability=false;

  for(let i=0;i<7;i++){
    const date=new Date(startDate);
    date.setDate(startDate.getDate()+i);
    const dayName=DAYS[date.getDay()];
    const daySlots=slots.filter(function(s){ return s.day===dayName; });
    const card=document.createElement('div');
    card.className='week-day';
    if(isPastDate(date)) card.classList.add('past'); else card.classList.add('bookable');
    if(normalizeDate(date).getTime()===normalizeDate(selectedDate).getTime()) card.classList.add('selected');

    // Track if day has slots for availability check
    if(daySlots.length){
      hasAvailability=true;
    }

    // Don't show slot count badge anymore - keep day cards clean
    
    card.innerHTML=
      '<div class="w-dow">'+DOW_SHORT[date.getDay()].toUpperCase()+'</div>'+
      '<div class="w-date'+(normalizeDate(date).getTime()===today.getTime()?' today':'')+'">'+date.getDate()+'</div>'+
      (!isPastDate(date) ?
        '<button class="w-add-btn" type="button" onclick="event.stopPropagation();openAddModal(\''+dayName+'\',new Date('+date.getTime()+'))">'+
          '<svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>'+
          ' Add Slot'+
        '</button>'
      : '');

    if(!isPastDate(date)){
      let scrollStartX = 0;
      let isScrolling = false;

      card.addEventListener('pointerdown', function(e) {
        scrollStartX = e.clientX;
        isScrolling = false;
      }, { passive: true });

      card.addEventListener('pointermove', function(e) {
        const moveDistance = Math.abs(e.clientX - scrollStartX);
        if (moveDistance > 15) {
          isScrolling = true;
        }
      }, { passive: true });

      card.addEventListener('pointerup', function(e) {
        if (isScrolling) {
          isScrolling = false;
          return;
        }
        // Clicking the card background (not the add button)? show day panel
        if(!e.target.closest('.w-add-btn')){
          selectedDate=new Date(date);
          viewMonthDate=new Date(date.getFullYear(), date.getMonth(), 1);
          renderMiniCalendar(); renderWeekStrip();
          showDayPanel(dayName, date);
        }
      }, { passive: true });
    }
    strip.appendChild(card);
  }
  empty.style.display=hasAvailability?'none':'block';
}

