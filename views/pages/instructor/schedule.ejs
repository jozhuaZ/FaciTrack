<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
.gcal-wrap{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:1.35rem;box-shadow:0 2px 8px rgba(0,0,0,0.04);cursor:default;position:relative;overflow:visible;pointer-events:auto;}
.gcal-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:1.15rem;pointer-events:auto;}
.gcal-title{font-size:1.08rem;font-weight:700;color:#111827;pointer-events:auto;}
.gcal-tz{font-size:.79rem;color:#6b7280;pointer-events:auto;}
.gcal-body{display:grid;grid-template-columns:230px 1fr;gap:1.25rem;overflow:visible;pointer-events:auto;}
.mini-cal{border-right:1px solid #e5e7eb;padding-right:1.15rem}
.mini-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:.7rem}
.mini-month{font-size:.84rem;font-weight:700;color:#111827}
.mini-nav{display:flex;gap:.3rem}
.mini-btn{width:26px;height:26px;border:1px solid #d1d5db;border-radius:7px;background:#fff;cursor:pointer;transition:all 0.2s ease}
.mini-btn:hover{border-color:#1a73e8;background:rgba(26,115,232,0.05)}
.mini-btn:disabled{opacity:.35;cursor:not-allowed}
.mini-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:3px}
.mini-dow{font-size:.62rem;color:#6b7280;text-align:center;font-weight:700}
.mini-day{height:26px;display:flex;align-items:center;justify-content:center;border-radius:999px;font-size:.72rem;color:#374151;transition:all 0.15s ease}
.mini-day.other{color:#d1d5db}
.mini-day.past{color:#d1d5db;background:#f9fafb;cursor:not-allowed}
.mini-day.bookable{cursor:pointer}
.mini-day.today{outline:2px solid #1a73e8;outline-offset:-2px;font-weight:700}
.mini-day.selected{background:#1a73e8;color:#fff;font-weight:700}
.mini-day.bookable:hover{background:rgba(26,115,232,.15);transform:scale(1.1)}
.week-strip-wrapper{width:100%;pointer-events:auto;touch-action:pan-x;}
.week-strip{display:grid;grid-template-columns:repeat(7,1fr);gap:.3rem;cursor:default;position:relative;width:100%;pointer-events:auto;}
.week-day{height:auto;min-height:100px;min-width:80px;border:1.5px solid #e5e7eb;border-radius:11px;padding:.5rem .3rem;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#fff;transition:all 0.2s ease;box-sizing:border-box;pointer-events:auto;touch-action:manipulation;user-select:none;-webkit-user-select:none;-webkit-touch-callout:none;-webkit-tap-highlight-color:transparent;}
.week-day.past{background:#f9fafb;opacity:.6;cursor:not-allowed}
.week-day.bookable{cursor:pointer}
.week-day.bookable:hover{border-color:#1a73e8;background:rgba(26,115,232,.03);transform:translateY(-2px);box-shadow:0 4px 12px rgba(26,115,232,0.12)}
.week-day.selected{border-color:#1a73e8;border-width:2px;box-shadow:0 0 0 3px rgba(26,115,232,.15);background:rgba(26,115,232,.02)}
.w-dow{text-align:center;font-size:.55rem;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.02em}
.w-date{text-align:center;font-size:1.25rem;font-weight:700;color:#111827;margin-top:.15rem}
.w-date.today{color:#1a73e8}
.w-slot{font-size:.55rem;background:#1a73e8;color:#fff;padding:.15rem .3rem;border-radius:4px;margin-top:.2rem;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:block;}
.w-slot.closed{background:#9ca3af}
.week-empty{text-align:center;padding:1.2rem .3rem;color:var(--gray-500);font-size:.7rem;}
.week-empty a{font-size:.82rem;color:#1a73e8;text-decoration:none}

/* compact modal style aligned with system */
#slotModal,
#slotViewOverlay {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1.5rem;
}
#slotModal .modal-content,
#slotViewOverlay .modal-content {
  width: min(100%, 560px);
  max-width: 560px;
  margin: auto;
  border-radius: 16px;
  box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
}
#slotViewOverlay .modal-content {
  max-width: 440px;
}
#slotModal .modal-body,
#slotViewOverlay .modal-body {
  max-height: 70vh;
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
  padding: 1.5rem;
}
.slot-form-group{margin-bottom:1rem;width:100%;}

