<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
/* ── Duration Settings Styles ── */
.duration-setting-group{margin-bottom:1.25rem}
.duration-setting-group:last-of-type{margin-bottom:0}
.duration-picker{display:flex;align-items:center;gap:.5rem;background:var(--gray-50);padding:.625rem;border-radius:var(--radius-md);border:1px solid var(--gray-200);max-width:280px}
.duration-btn{width:36px;height:36px;border:1.5px solid var(--gray-300);border-radius:var(--radius-md);background:#fff;color:var(--gray-700);font-size:1.25rem;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0}
.duration-btn:hover{border-color:var(--primary-blue);color:var(--primary-blue);background:rgba(10,61,98,.04)}
.duration-btn:active{transform:scale(.95)}
.duration-input{width:60px;text-align:center;border:none;background:transparent;font-size:1.125rem;font-weight:700;color:var(--gray-900);padding:.25rem;outline:none;-moz-appearance:textfield}
.duration-input::-webkit-inner-spin-button,.duration-input::-webkit-outer-spin-button{-webkit-appearance:none}
.duration-unit{font-size:.8125rem;color:var(--gray-500);font-weight:600;margin-left:.25rem}
.btn-edit-duration{width:24px;height:24px;border:1px solid var(--gray-300);border-radius:4px;background:#fff;color:var(--gray-600);cursor:pointer;display:inline-flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0}
.btn-edit-duration:hover{border-color:var(--primary-blue);color:var(--primary-blue);background:rgba(10,61,98,.04)}
.sync-option-group{display:flex;flex-direction:column;gap:1rem}
.sync-option-card{display:flex;align-items:center;gap:1rem;padding:1rem;border:1.5px solid var(--gray-200);border-radius:var(--radius-lg);background:#fff;transition:all .2s}
.sync-option-card:hover{border-color:var(--gray-300);box-shadow:0 2px 8px rgba(0,0,0,.08)}
.sync-option-icon{width:48px;height:48px;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sync-option-icon.apple{background:linear-gradient(135deg,#000,#333);color:#fff}
.sync-option-icon.google{background:#fff;border:1px solid var(--gray-200)}
.sync-option-content{flex:1}
.sync-option-title{font-size:.9375rem;font-weight:700;color:var(--gray-900);margin:0 0 .25rem}
.sync-option-desc{font-size:.8125rem;color:var(--gray-600);margin:0}
.sync-download-btn{display:inline-flex;align-items:center;gap:.5rem;padding:.5rem 1rem;background:var(--primary-blue);color:#fff;border:none;border-radius:var(--radius-md);font-size:.8125rem;font-weight:600;cursor:pointer;transition:all .2s;font-family:var(--font-body);flex-shrink:0}
.sync-download-btn:hover{background:var(--primary-dark);transform:translateY(-1px);box-shadow:0 4px 12px rgba(10,61,98,.25)}
.consult-type-badge{display:inline-flex;align-items:center;gap:.375rem;padding:.25rem .625rem;border-radius:var(--radius-full);font-size:.75rem;font-weight:600;background:var(--gray-100);color:var(--gray-700)}
.consult-type-badge.online{background:#dbeafe;color:#1e40af}
.consult-type-badge.physical{background:#f0fdf4;color:#15803d}
.gmeet-action-btn{display:inline-flex;align-items:center;gap:.375rem;padding:.375rem .75rem;background:#0284c7;color:#fff;border:none;border-radius:6px;font-size:.75rem;font-weight:600;cursor:pointer;transition:all .2s;font-family:var(--font-body)}
.gmeet-action-btn:hover{background:#0369a1;transform:translateY(-1px)}
.gmeet-copy-btn{width:28px;height:28px;border:1px solid#bae6fd;border-radius:4px;background:#fff;color:#0284c7;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0}
.gmeet-copy-btn:hover{background:#e0f2fe;border-color:#0284c7}
.gmeet-secondary-btn{display:inline-flex;align-items:center;gap:.375rem;padding:.375rem .75rem;background:#fff;color:#0369a1;border:1px solid #bae6fd;border-radius:6px;font-size:.75rem;font-weight:600;cursor:pointer;transition:all .2s;font-family:var(--font-body);flex:1}
.gmeet-secondary-btn:hover{background:#e0f2fe;border-color:#0284c7}
.log-config-section{margin-bottom:1.25rem}
.log-date-range{display:flex;align-items:center;gap:.75rem}
.log-date-input{flex:1;padding:.625rem;border:1.5px solid var(--gray-200);border-radius:var(--radius-md);font-size:.875rem;font-family:var(--font-body);transition:all .2s}
.log-date-input:focus{outline:none;border-color:var(--primary-blue);box-shadow:0 0 0 3px rgba(10,61,98,.1)}
.log-checkboxes{display:grid;grid-template-columns:repeat(2,1fr);gap:.625rem}
.log-checkbox-item{display:flex;align-items:center;gap:.5rem;padding:.625rem;border:1.5px solid var(--gray-200);border-radius:var(--radius-md);cursor:pointer;transition:all .2s;font-size:.8125rem;color:var(--gray-700)}
.log-checkbox-item:hover{border-color:var(--gray-300);background:var(--gray-50)}
.log-checkbox-item input[type="checkbox"]{width:16px;height:16px;cursor:pointer}
.log-checkbox-item input[type="checkbox"]:checked + span{font-weight:600;color:var(--gray-900)}
.log-preview-section{margin:1.25rem 0;border:1.5px solid var(--gray-200);border-radius:var(--radius-lg);overflow:hidden}
.log-preview-header{display:flex;justify-content:space-between;align-items:center;padding:.75rem 1rem;background:var(--gray-50);border-bottom:1px solid var(--gray-200)}
.log-preview-content{max-height:280px;overflow-y:auto;padding:1rem;background:#fff}
.log-preview-item{padding:.75rem;border-left:3px solid var(--primary-blue);background:var(--gray-50);border-radius:4px;margin-bottom:.5rem;font-size:.8125rem}
.log-preview-item:last-child{margin-bottom:0}
.log-preview-date{font-weight:700;color:var(--gray-900);margin-bottom:.5rem;font-size:.875rem}
.log-preview-apt{display:flex;justify-content:space-between;color:var(--gray-700);margin-bottom:.25rem}
.log-export-options{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;margin-top:1.25rem}
.log-export-btn{display:flex;flex-direction:column;align-items:center;gap:.5rem;padding:1rem;border:1.5px solid var(--gray-200);border-radius:var(--radius-lg);background:#fff;cursor:pointer;transition:all .2s;font-family:var(--font-body);font-size:.8125rem;font-weight:600;color:var(--gray-700)}
.log-export-btn:hover{border-color:var(--primary-blue);color:var(--primary-blue);transform:translateY(-2px);box-shadow:0 4px 12px rgba(10,61,98,.15)}
.log-export-btn.pdf:hover{border-color:#dc2626;color:#dc2626}
.log-export-btn.word:hover{border-color:#2563eb;color:#2563eb}
.log-export-btn.print:hover{border-color:#15803d;color:#15803d}

/* ── Calendar View Styles ── */
.cal-view-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:1.25rem;flex-wrap:wrap;gap:1rem}
.cal-view-nav{display:flex;align-items:center;gap:.5rem}
.cal-view-nav-btn{width:36px;height:36px;border:1.5px solid var(--gray-200);border-radius:var(--radius-md);background:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--gray-600);transition:all .2s}
.cal-view-nav-btn:hover{border-color:var(--primary-blue);color:var(--primary-blue);background:rgba(10,61,98,.04)}
.cal-view-title{font-size:1.125rem;font-weight:700;color:var(--gray-900);margin:0 .75rem}
.cal-add-event-btn{display:inline-flex;align-items:center;gap:.5rem;padding:.625rem 1.125rem;background:var(--primary-blue);color:#fff;border:none;border-radius:var(--radius-md);font-size:.875rem;font-weight:600;cursor:pointer;transition:all .2s;font-family:var(--font-body)}
.cal-add-event-btn:hover{background:var(--primary-dark);transform:translateY(-1px);box-shadow:0 4px 12px rgba(10,61,98,.25)}
.cal-view-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:1px;background:var(--gray-200);border:1px solid var(--gray-200);border-radius:var(--radius-lg);overflow:hidden}
.cal-view-day-label{background:var(--gray-50);padding:.625rem;text-align:center;font-size:.75rem;font-weight:700;color:var(--gray-600);text-transform:uppercase;letter-spacing:.5px}
.cal-view-cell{background:#fff;min-height:110px;padding:.5rem;position:relative;border-bottom:1px solid var(--gray-100)}
.cal-view-cell.other-month{background:var(--gray-50);opacity:.6}
.cal-view-cell.today{background:rgba(10,61,98,.03)}
.cal-view-date{font-size:.875rem;font-weight:700;color:var(--gray-800);margin-bottom:.375rem}
.cal-view-date.today{color:var(--primary-blue)}
.cal-view-events{display:flex;flex-direction:column;gap:.25rem}
.cal-event-item{font-size:.6875rem;padding:.25rem .375rem;border-radius:4px;cursor:pointer;transition:all .15s;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:flex;align-items:center;gap:.25rem}
.cal-event-item.appointment.pending{background:#fef3c7;color:#92400e;border-left:3px solid #fbbf24}
.cal-event-item.appointment.confirmed{background:#d1fae5;color:#065f46;border-left:3px solid#10b981}
.cal-event-item.appointment.declined{background:#fee2e2;color:#991b1b;border-left:3px solid #ef4444}
.cal-event-item.task{background:#dbeafe;color:#1e40af;border-left:3px solid #3b82f6}
.cal-event-item.event{background:#e9d5ff;color:#6b21a8;border-left:3px solid #a855f7}
.cal-event-item:hover{transform:translateX(2px);box-shadow:0 2px 6px rgba(0,0,0,.1)}

/* ── Decline modal calendar ── */
.decline-cal-wrap { margin-top:1rem; border:1px solid var(--gray-200); border-radius:var(--radius-md); overflow:hidden; }
.decline-cal-header { display:flex; align-items:center; justify-content:space-between; padding:.625rem 1rem; background:var(--gray-50); border-bottom:1px solid var(--gray-200); }
.decline-cal-title { font-size:.8125rem; font-weight:700; color:var(--gray-700); }
.decline-cal-nav { display:flex; gap:.25rem; }
.decline-cal-nav button { width:24px; height:24px; border:1px solid var(--gray-200); border-radius:4px; background:#fff; cursor:pointer; display:flex; align-items:center; justify-content:center; color:var(--gray-500); font-size:.75rem; }
.decline-cal-nav button:hover { border-color:var(--primary-blue); color:var(--primary-blue); }
.decline-cal-grid { display:grid; grid-template-columns:repeat(7,1fr); padding:.5rem; gap:2px; }
.dcal-lbl { text-align:center; font-size:.625rem; font-weight:700; color:var(--gray-400); text-transform:uppercase; padding:.25rem 0; }
.dcal-cell { aspect-ratio:1; display:flex; align-items:center; justify-content:center; font-size:.75rem; color:var(--gray-400); border-radius:4px; }
.dcal-cell.other { color:var(--gray-300); }
.dcal-cell.today { font-weight:700; color:var(--primary-blue); }
.dcal-cell.avail { background:rgba(34,197,94,.15); color:#15803d; font-weight:700; cursor:default; }
.dcal-cell.avail:hover { background:rgba(34,197,94,.25); }
.decline-cal-legend { padding:.375rem .75rem; font-size:.6875rem; color:var(--gray-500); display:flex; align-items:center; gap:.375rem; border-top:1px solid var(--gray-100); }
.decline-cal-legend-dot { width:8px; height:8px; border-radius:2px; background:rgba(34,197,94,.4); }

/* ── View Details Modal ── */
.view-detail-row { display:flex; gap:.5rem; margin-bottom:.75rem; align-items:flex-start; }
.view-detail-label { font-size:.75rem; font-weight:700; color:var(--gray-500); text-transform:uppercase; letter-spacing:.4px; min-width:90px; flex-shrink:0; padding-top:1px; }
.view-detail-value { font-size:.875rem; color:var(--gray-800); line-height:1.5; }
.view-detail-divider { border:none; border-top:1px solid var(--gray-100); margin:.875rem 0; }
.view-student-header { display:flex; align-items:center; gap:.875rem; margin-bottom:1.25rem; padding-bottom:1rem; border-bottom:1px solid var(--gray-100); }
.view-student-avatar { width:44px; height:44px; border-radius:50%; background:var(--primary-blue); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:.9375rem; flex-shrink:0; }

/* ── Pagination ── */
.pagination-wrap { display:flex; align-items:center; justify-content:space-between; padding:1rem 1.25rem; border-top:1px solid var(--gray-100); flex-wrap:wrap; gap:.75rem; }
.pagination-info { font-size:.8125rem; color:var(--gray-500); }
.pagination-controls { display:flex; align-items:center; gap:.375rem; }
.pg-btn { width:34px; height:34px; border:1.5px solid var(--gray-200); border-radius:var(--radius-md); background:#fff; color:var(--gray-600); font-size:.8125rem; font-weight:600; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all .18s; font-family:var(--font-body); }
.pg-btn:hover:not(:disabled) { border-color:var(--primary-blue); color:var(--primary-blue); background:rgba(10,61,98,.04); }
.pg-btn:disabled { opacity:.4; cursor:not-allowed; }
.pg-btn.active { background:var(--primary-blue); color:#fff; border-color:var(--primary-blue); }
.pg-btn.pg-arrow { font-size:1rem; }

/* ── View button on card ── */
.btn-view-consult { display:inline-flex; align-items:center; justify-content:center; gap:.35rem; padding:.4rem .75rem; border:1.5px solid var(--gray-200); border-radius:var(--radius-md); background:#fff; color:var(--gray-600); font-size:.75rem; font-weight:600; cursor:pointer; transition:all .18s; font-family:var(--font-body); width:100%; box-sizing:border-box; }
.btn-view-consult:hover { border-color:var(--primary-blue); color:var(--primary-blue); background:rgba(10,61,98,.04); }
@media (max-width: 640px) {
    .view-detail-row { flex-direction:column; gap:.25rem; }
    .view-detail-label { min-width:0; }
    .view-student-header { align-items:flex-start; }
    .pagination-wrap { flex-direction:column; align-items:flex-start; }
}
</style>

<div class="instructor-layout">
    <%- include('../../partials/instructor-sidebar', { activePage: 'consultations', pendingCount: appointments.filter(a => a.status === 'pending').length }) %>

    <main class="instructor-main">
        <div class="main-container">

            <div class="page-header">
                <div>
                    <h1 class="page-title">Appointments</h1>
                    <p class="page-subtitle">Manage all appointment requests from students</p>
                </div>
                <div class="header-actions">
                    <button class="btn-header-action" id="generateLogsBtn">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                        Generate Logs
                    </button>
                    <button class="btn-header-action" id="calendarSyncBtn">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        Sync Calendar
                    </button>
                    <button class="btn-header-action" id="durationSettingsBtn">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        Duration Settings
                    </button>
                </div>
            </div>

            <!-- Clean Search & Filter Bar -->
            <style>
            .search-filter-bar{display:flex;gap:1rem;padding:1.25rem;background:#fff;border-radius:12px;margin-bottom:1.5rem;border:1px solid #e5e7eb;align-items:center;flex-wrap:wrap}
            .search-input-wrap{flex:1;min-width:200px;display:flex;align-items:center;gap:.5rem;border:1.5px solid #e5e7eb;border-radius:10px;padding:0 .875rem;background:#fff}
            .search-input-wrap svg{color:#94a3b8;flex-shrink:0;width:16px;height:16px}
            .search-input-wrap input{flex:1;border:none;padding:.625rem 0;font-size:.9125rem;background:transparent;outline:none;color:#0f172a}
            .search-input-wrap input::placeholder{color:#cbd5e1}
            .search-input-wrap input:focus{outline:none}
            .filter-dropdown-wrap{display:flex;align-items:center}
            .filter-dropdown{border:1.5px solid #e5e7eb;border-radius:10px;padding:.625rem 1rem;background:#fff;color:#374151;font-size:.9125rem;font-weight:500;cursor:pointer;font-family:inherit;min-width:160px;transition:all .2s}
            .filter-dropdown:hover{border-color:#3b82f6;color:#3b82f6}
            .view-toggle-wrap{display:flex;gap:.375rem;padding:.25rem;background:#f3f4f6;border-radius:10px}
            .view-toggle-btn{width:40px;height:40px;border:none;background:transparent;color:#6b7280;cursor:pointer;border-radius:8px;display:flex;align-items:center;justify-content:center;transition:all .2s}
            .view-toggle-btn:hover{background:#e5e7eb;color:#374151}
            .view-toggle-btn.active{background:#fff;color:#3b82f6;box-shadow:0 1px 3px rgba(0,0,0,.1)}
            </style>

            <div class="search-filter-bar">
              <div class="search-input-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" id="consultSearch" autocomplete="off">
              </div>
              <div class="filter-dropdown-wrap">
                <select class="filter-dropdown" id="consultStatusFilter">
                  <option value="all">All Statuses</option>
                  <option value="pending">Pending</option>
                  <option value="confirmed">Confirmed</option>
                  <option value="declined">Declined</option>
                </select>
              </div>
              <!-- View Toggle: List or Calendar -->
              <div class="view-toggle-wrap">
                <button class="view-toggle-btn active" data-view="list" title="List View">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                </button>
                <button class="view-toggle-btn" data-view="calendar" title="Calendar View">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </button>
              </div>
            </div>

            <!-- Consultations List wrapped in a card for pagination footer -->
            <div class="content-card" id="listView" style="padding:0;">
                <div class="consultations-list" id="consultationsList" style="padding:.75rem;">
                    <% appointments.forEach((apt, idx) => { %>
                    <div class="consultation-card" data-status="<%= apt.status %>" data-index="<%= idx %>"
                         data-student="<%= apt.studentName %>" data-studentid="<%= apt.studentId %>"
                         data-date="<%= apt.date %>" data-time="<%= apt.time %>" data-duration="<%= apt.duration %>"
                         data-topic="<%= apt.topic %>" data-requested="<%= apt.requestedAt %>" data-id="<%= apt.id %>">
                        <div class="consult-card-left"></div>
                        <div class="consult-card-body">
                            <div class="consult-card-top">
                                <div>
                                    <h4 class="consult-student-name"><%= apt.studentName %></h4>
                                    <p class="consult-student-id"><%= apt.studentId %></p>
                                </div>
                                <span class="consult-status-badge <%= apt.status %>">
                                    <%= apt.status.charAt(0).toUpperCase() + apt.status.slice(1) %>
                                </span>
                            </div>
                            <p class="consult-topic"><%= apt.topic %></p>
                            <div class="consult-meta">
                                <span>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                    <%= apt.date %>
                                </span>
                                <span>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                    <%= apt.time %> · <%= apt.duration %>
                                </span>
                                <span class="consult-requested">Requested <%= apt.requestedAt %></span>
                            </div>
                        </div>
                        <div class="consult-card-actions" style="display:flex;flex-direction:column;gap:.4rem;align-items:stretch;width:120px;">
                            <!-- View Details button always visible -->
                            <button class="btn-view-consult btn-view-details" data-index="<%= idx %>">
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                View
                            </button>
                            <% if (apt.status === 'pending') { %>
                            <button class="btn-approve-full" data-id="<%= apt.id %>" data-student="<%= apt.studentName %>" style="width:100%;justify-content:center;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                Approve
                            </button>
                            <button class="btn-decline-full" data-id="<%= apt.id %>" data-student="<%= apt.studentName %>" style="width:100%;justify-content:center;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                Decline
                            </button>
                            <% } %>
                        </div>
                    </div>
                    <% }); %>
                </div>

