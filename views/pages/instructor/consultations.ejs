// ── Calendar View Logic ──
const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
let calViewYear = new Date().getFullYear();
let calViewMonth = new Date().getMonth();

// Store custom events/tasks (in real app, this would come from backend)
let customEvents = [];

function parseAppointmentDate(dateStr) {
    // Parse date strings like "Monday, January 20, 2026"
    const months = {Jan:0,Feb:1,Mar:2,Apr:3,May:4,Jun:5,Jul:6,Aug:7,Sep:8,Oct:9,Nov:10,Dec:11,
                    January:0,February:1,March:2,April:3,May:4,June:5,July:6,August:7,September:8,October:9,November:10,December:11};
    const parts = dateStr.replace(/,/g, '').split(' ');
    const month = months[parts[1]];
    const day = parseInt(parts[2]);
    const year = parseInt(parts[3]);
    return new Date(year, month, day);
}

function renderCalendarView() {
    const grid = document.getElementById('calViewGrid');
    const title = document.getElementById('calViewTitle');
    
    title.textContent = `${monthNames[calViewMonth]} ${calViewYear}`;
    grid.innerHTML = '';
    
    // Day labels
    dayNames.forEach(d => {
        const lbl = document.createElement('div');
        lbl.className = 'cal-view-day-label';
        lbl.textContent = d;
        grid.appendChild(lbl);
    });
    
    const firstDay = new Date(calViewYear, calViewMonth, 1).getDay();
    const daysInMonth = new Date(calViewYear, calViewMonth + 1, 0).getDate();
    const daysInPrev = new Date(calViewYear, calViewMonth, 0).getDate();
    const today = new Date();
    
    // Previous month days
    for (let i = firstDay - 1; i >= 0; i--) {
        const cell = document.createElement('div');
        cell.className = 'cal-view-cell other-month';
        const dateDiv = document.createElement('div');
        dateDiv.className = 'cal-view-date';
        dateDiv.textContent = daysInPrev - i;
        cell.appendChild(dateDiv);
        grid.appendChild(cell);
    }
    
    // Current month days
    for (let d = 1; d <= daysInMonth; d++) {
        const cell = document.createElement('div');
        cell.className = 'cal-view-cell';
        
        const cellDate = new Date(calViewYear, calViewMonth, d);
        const isToday = cellDate.toDateString() === today.toDateString();
        if (isToday) cell.classList.add('today');
        
        const dateDiv = document.createElement('div');
        dateDiv.className = 'cal-view-date' + (isToday ? ' today' : '');
        dateDiv.textContent = d;
        cell.appendChild(dateDiv);
        
        // Events container
        const eventsDiv = document.createElement('div');
        eventsDiv.className = 'cal-view-events';
        
        // Add appointments for this date
        const cards = document.querySelectorAll('.consultation-card');
        cards.forEach(card => {
            try {
                const aptDate = parseAppointmentDate(card.dataset.date);
                if (aptDate.getDate() === d && aptDate.getMonth() === calViewMonth && aptDate.getFullYear() === calViewYear) {
                    const eventItem = document.createElement('div');
                    eventItem.className = `cal-event-item appointment ${card.dataset.status}`;
                    eventItem.innerHTML = `<span>${card.dataset.time.split(' ')[0]}</span> ${card.dataset.student}`;
                    eventItem.addEventListener('click', () => {
                        // Trigger view details
                        const viewBtn = card.querySelector('.btn-view-details');
                        if (viewBtn) viewBtn.click();
                    });
                    eventsDiv.appendChild(eventItem);
                }
            } catch(e) { /* ignore parse errors */ }
        });
        
        // Add custom events for this date
        customEvents.forEach(event => {
            const evtDate = new Date(event.date);
            if (evtDate.getDate() === d && evtDate.getMonth() === calViewMonth && evtDate.getFullYear() === calViewYear) {
                const eventItem = document.createElement('div');
                eventItem.className = `cal-event-item ${event.type}`;
                const timeStr = event.time ? event.time + ' ' : '';
                eventItem.innerHTML = `<span>${timeStr}</span>${event.title}`;
                eventsDiv.appendChild(eventItem);
            }
        });
        
        cell.appendChild(eventsDiv);
        grid.appendChild(cell);
    }
    
    // Next month days to fill grid
    const totalCells = firstDay + daysInMonth;
    const remaining = totalCells % 7 === 0 ? 0 : 7 - (totalCells % 7);
    for (let i = 1; i <= remaining; i++) {
        const cell = document.createElement('div');
        cell.className = 'cal-view-cell other-month';
        const dateDiv = document.createElement('div');
        dateDiv.className = 'cal-view-date';
        dateDiv.textContent = i;
        cell.appendChild(dateDiv);
        grid.appendChild(cell);
    }
}

document.getElementById('calViewPrev').addEventListener('click', () => {
    calViewMonth--;
    if (calViewMonth < 0) { calViewMonth = 11; calViewYear--; }
    renderCalendarView();
});

document.getElementById('calViewNext').addEventListener('click', () => {
    calViewMonth++;
    if (calViewMonth > 11) { calViewMonth = 0; calViewYear++; }
    renderCalendarView();
});

