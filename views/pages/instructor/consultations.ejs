// Update preview when date or filters change
document.getElementById('logStartDate').addEventListener('change', updateLogPreview);
document.getElementById('logEndDate').addEventListener('change', updateLogPreview);
document.querySelectorAll('#generateLogsModal input[type="checkbox"]').forEach(cb => {
    cb.addEventListener('change', updateLogPreview);
});

function updateLogPreview() {
    const startDate = new Date(document.getElementById('logStartDate').value);
    const endDate = new Date(document.getElementById('logEndDate').value);
    const includeConfirmed = document.getElementById('logIncludeConfirmed').checked;
    const includePending = document.getElementById('logIncludePending').checked;
    const includeDeclined = document.getElementById('logIncludeDeclined').checked;
    const showDuration = document.getElementById('logShowDuration').checked;
    const showTopic = document.getElementById('logShowTopic').checked;
    const showStudentId = document.getElementById('logShowStudentId').checked;
    const groupByDate = document.getElementById('logGroupByDate').checked;
    
    if (!startDate || !endDate) {
        document.getElementById('logPreviewContent').innerHTML = '<p style="text-align:center;color:var(--gray-400);font-size:.8125rem;padding:2rem;">Select date range to preview logs</p>';
        return;
    }
    
    const cards = Array.from(document.querySelectorAll('.consultation-card'));
    const filtered = cards.filter(card => {
        const status = card.dataset.status;
        if (!includeConfirmed && status === 'confirmed') return false;
        if (!includePending && status === 'pending') return false;
        if (!includeDeclined && status === 'declined') return false;
        
        try {
            const aptDate = parseAppointmentDate(card.dataset.date);
            return aptDate >= startDate && aptDate <= endDate;
        } catch(e) { return false; }
    });
    
    document.getElementById('logPreviewCount').textContent = `${filtered.length} appointment${filtered.length !== 1 ? 's' : ''}`;
    
    if (filtered.length === 0) {
        document.getElementById('logPreviewContent').innerHTML = '<p style="text-align:center;color:var(--gray-400);font-size:.8125rem;padding:2rem;">No appointments found in selected range</p>';
        return;
    }
    
    let html = '';
    
    if (groupByDate) {
        const grouped = {};
        filtered.forEach(card => {
            const date = card.dataset.date;
            if (!grouped[date]) grouped[date] = [];
            grouped[date].push(card);
        });
        
        Object.keys(grouped).sort((a, b) => {
            try {
                return parseAppointmentDate(a) - parseAppointmentDate(b);
            } catch(e) { return 0; }
        }).forEach(date => {
            html += `<div class="log-preview-date">${date}</div>`;
            grouped[date].forEach(card => {
                html += formatLogPreviewItem(card, showDuration, showTopic, showStudentId);
            });
        });
    } else {
        filtered.forEach(card => {
            html += formatLogPreviewItem(card, showDuration, showTopic, showStudentId, true);
        });
    }
    
    document.getElementById('logPreviewContent').innerHTML = html;
}

function formatLogPreviewItem(card, showDuration, showTopic, showStudentId, showDate = false) {
    const name = card.dataset.student;
    const studentId = card.dataset.studentid;
    const time = card.dataset.time;
    const duration = card.dataset.duration;
    const topic = card.dataset.topic;
    const status = card.dataset.status;
    const date = card.dataset.date;
    
    let html = '<div class="log-preview-item">';
    html += '<div class="log-preview-apt">';
    html += `<span><strong>${name}</strong>`;
    if (showStudentId) html += ` (${studentId})`;
    html += `</span>`;
    html += `<span class="consult-status-badge ${status}" style="font-size:.6875rem;padding:.125rem .5rem;">${status}</span>`;
    html += '</div>';
    if (showDate) html += `<div class="log-preview-apt"><span>${date}</span></div>`;
    html += `<div class="log-preview-apt"><span>${time}`;
    if (showDuration) html += ` · ${duration}`;
    html += `</span></div>`;
    if (showTopic) html += `<div class="log-preview-apt"><span style="color:var(--gray-600);font-style:italic;">${topic}</span></div>`;
    html += '</div>';
    
    return html;
}

// Export functions
function generateLogDocument(filtered, options) {
    let doc = '='.repeat(80) + '\n';
    doc += 'CONSULTATION LOGS REPORT\n';
    doc += 'Generated: ' + new Date().toLocaleString() + '\n';
    doc += 'Period: ' + document.getElementById('logStartDate').value + ' to ' + document.getElementById('logEndDate').value + '\n';
    doc += '='.repeat(80) + '\n\n';
    
    if (options.groupByDate) {
        const grouped = {};
        filtered.forEach(card => {
            const date = card.dataset.date;
            if (!grouped[date]) grouped[date] = [];
            grouped[date].push(card);
        });
        
        Object.keys(grouped).sort().forEach(date => {
            doc += `\n${date}\n`;
            doc += '-'.repeat(80) + '\n';
            grouped[date].forEach((card, idx) => {
                doc += `${idx + 1}. ${card.dataset.student}`;
                if (options.showStudentId) doc += ` (${card.dataset.studentid})`;
                doc += `\n   Time: ${card.dataset.time}`;
                if (options.showDuration) doc += ` · Duration: ${card.dataset.duration}`;
                doc += `\n   Status: ${card.dataset.status}`;
                if (options.showTopic) doc += `\n   Topic: ${card.dataset.topic}`;
                doc += '\n\n';
            });
        });
    } else {
        filtered.forEach((card, idx) => {
            doc += `${idx + 1}. ${card.dataset.student}`;
            if (options.showStudentId) doc += ` (${card.dataset.studentid})`;
            doc += `\n   Date: ${card.dataset.date}`;
            doc += `\n   Time: ${card.dataset.time}`;
            if (options.showDuration) doc += ` · Duration: ${card.dataset.duration}`;
            doc += `\n   Status: ${card.dataset.status}`;
            if (options.showTopic) doc += `\n   Topic: ${card.dataset.topic}`;
            doc += '\n\n';
        });
    }
    
    doc += '='.repeat(80) + '\n';
    doc += `Total Appointments: ${filtered.length}\n`;
    
    return doc;
}

function getFilteredAppointments() {
    const startDate = new Date(document.getElementById('logStartDate').value);
    const endDate = new Date(document.getElementById('logEndDate').value);
    const includeConfirmed = document.getElementById('logIncludeConfirmed').checked;
    const includePending = document.getElementById('logIncludePending').checked;
    const includeDeclined = document.getElementById('logIncludeDeclined').checked;
    
    const cards = Array.from(document.querySelectorAll('.consultation-card'));
    return cards.filter(card => {
        const status = card.dataset.status;
        if (!includeConfirmed && status === 'confirmed') return false;
        if (!includePending && status === 'pending') return false;
        if (!includeDeclined && status === 'declined') return false;
        
        try {
            const aptDate = parseAppointmentDate(card.dataset.date);
            return aptDate >= startDate && aptDate <= endDate;
        } catch(e) { return false; }
    });
}

