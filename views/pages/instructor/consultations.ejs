// Generate iCal format (Apple Calendar)
function generateICS(appointments, range) {
    let filtered = filterAppointmentsByRange(appointments, range);
    
    let ics = 'BEGIN:VCALENDAR\r\n';
    ics += 'VERSION:2.0\r\n';
    ics += 'PRODID:-//FaciTrack//Consultation Calendar//EN\r\n';
    ics += 'CALSCALE:GREGORIAN\r\n';
    ics += 'METHOD:PUBLISH\r\n';
    ics += 'X-WR-CALNAME:Consultation Appointments\r\n';
    ics += 'X-WR-TIMEZONE:Asia/Manila\r\n';
    
    filtered.forEach(apt => {
        const uid = `apt-${apt.id}@facitrack.edu`;
        const dtstart = formatDateTimeForICS(apt.date, apt.time);
        const dtend = calculateEndTime(dtstart, apt.duration);
        const summary = `Consultation: ${apt.studentName}`;
        const description = `Student: ${apt.studentName}\\nTopic: ${apt.topic}\\nStatus: ${apt.status}`;
        
        ics += 'BEGIN:VEVENT\r\n';
        ics += `UID:${uid}\r\n`;
        ics += `DTSTAMP:${formatDateTimeForICS(new Date())}\r\n`;
        ics += `DTSTART:${dtstart}\r\n`;
        ics += `DTEND:${dtend}\r\n`;
        ics += `SUMMARY:${summary}\r\n`;
        ics += `DESCRIPTION:${description}\r\n`;
        ics += `STATUS:${apt.status === 'confirmed' ? 'CONFIRMED' : 'TENTATIVE'}\r\n`;
        ics += 'END:VEVENT\r\n';
    });
    
    ics += 'END:VCALENDAR\r\n';
    return ics;
}

function formatDateTimeForICS(date, time) {
    if (date instanceof Date) {
        const y = date.getFullYear();
        const m = String(date.getMonth() + 1).padStart(2, '0');
        const d = String(date.getDate()).padStart(2, '0');
        const h = String(date.getHours()).padStart(2, '0');
        const min = String(date.getMinutes()).padStart(2, '0');
        return `${y}${m}${d}T${h}${min}00`;
    }
    
    // Parse date string like "Monday, January 20, 2026" and time like "2:00 PM"
    const dateObj = parseAppointmentDate(date);
    const [timeStr, period] = time.split(' ');
    let [hours, minutes] = timeStr.split(':').map(Number);
    if (period === 'PM' && hours !== 12) hours += 12;
    if (period === 'AM' && hours === 12) hours = 0;
    
    const y = dateObj.getFullYear();
    const m = String(dateObj.getMonth() + 1).padStart(2, '0');
    const d = String(dateObj.getDate()).padStart(2, '0');
    const h = String(hours).padStart(2, '0');
    const min = String(minutes).padStart(2, '0');
    return `${y}${m}${d}T${h}${min}00`;
}

function calculateEndTime(dtstart, duration) {
    const y = parseInt(dtstart.substr(0, 4));
    const m = parseInt(dtstart.substr(4, 2)) - 1;
    const d = parseInt(dtstart.substr(6, 2));
    const h = parseInt(dtstart.substr(9, 2));
    const min = parseInt(dtstart.substr(11, 2));
    
    const start = new Date(y, m, d, h, min);
    const durationMin = parseInt(duration) || 30;
    const end = new Date(start.getTime() + durationMin * 60000);
    
    const ey = end.getFullYear();
    const em = String(end.getMonth() + 1).padStart(2, '0');
    const ed = String(end.getDate()).padStart(2, '0');
    const eh = String(end.getHours()).padStart(2, '0');
    const emin = String(end.getMinutes()).padStart(2, '0');
    return `${ey}${em}${ed}T${eh}${emin}00`;
}

function filterAppointmentsByRange(appointments, range) {
    const now = new Date();
    return appointments.filter(apt => {
        if (range === 'confirmed') return apt.status === 'confirmed';
        if (range === 'all') return true;
        
        try {
            const aptDate = parseAppointmentDate(apt.date);
            if (range === 'upcoming') return aptDate >= now;
            if (range === 'past') return aptDate < now;
        } catch(e) { return true; }
        return true;
    });
}

function downloadFile(content, filename, type) {
    const blob = new Blob([content], { type });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
}

