<!-- Generate Logs Modal -->
<div class="modal-overlay" id="generateLogsModal">
    <div class="modal-content" style="max-width:680px;">
        <div class="modal-header">
            <h3 class="modal-title">Generate Consultation Logs</h3>
            <button class="modal-close" id="closeGenerateLogsModal">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="modal-body">
            <p class="modal-description">Generate formatted consultation logs for reporting and documentation purposes.</p>
            
            <!-- Log Configuration -->
            <div class="log-config-section">
                <label class="modal-label">Date Range</label>
                <div class="log-date-range">
                    <input type="date" id="logStartDate" class="log-date-input">
                    <span style="color:var(--gray-400);font-weight:600;">to</span>
                    <input type="date" id="logEndDate" class="log-date-input">
                </div>
            </div>

            <div class="log-config-section">
                <label class="modal-label">Include</label>
                <div class="log-checkboxes">
                    <label class="log-checkbox-item">
                        <input type="checkbox" id="logIncludeConfirmed" checked>
                        <span>Confirmed Appointments</span>
                    </label>
                    <label class="log-checkbox-item">
                        <input type="checkbox" id="logIncludePending">
                        <span>Pending Requests</span>
                    </label>
                    <label class="log-checkbox-item">
                        <input type="checkbox" id="logIncludeDeclined">
                        <span>Declined Requests</span>
                    </label>
                </div>
            </div>

            <div class="log-config-section">
                <label class="modal-label">Format Options</label>
                <div class="log-checkboxes">
                    <label class="log-checkbox-item">
                        <input type="checkbox" id="logShowDuration" checked>
                        <span>Show Duration</span>
                    </label>
                    <label class="log-checkbox-item">
                        <input type="checkbox" id="logShowTopic" checked>
                        <span>Show Topics</span>
                    </label>
                    <label class="log-checkbox-item">
                        <input type="checkbox" id="logShowStudentId" checked>
                        <span>Show Student IDs</span>
                    </label>
                    <label class="log-checkbox-item">
                        <input type="checkbox" id="logGroupByDate" checked>
                        <span>Group by Date</span>
                    </label>
                </div>
            </div>

