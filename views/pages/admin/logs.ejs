<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
@media print {
  .instructor-sidebar,.sidebar-footer,.header-actions,.stats-overview,.pagination-bar,.toast-container,.page-header,.print-report-header,.filter-bar-container{display:none!important}
  .instructor-layout{display:block!important}
  .instructor-main{overflow:visible!important}
  .main-container{padding:0!important;gap:1rem!important}
  .content-card{box-shadow:none!important;border:1px solid #e5e7eb!important;break-inside:avoid}
  .data-table{margin:0;padding:0;width:100%;border-collapse:collapse}
  .data-table td,.data-table th{padding:8px;border:1px solid #e5e7eb;font-size:11px}
  body{background:#fff!important}
}
.print-report-header{display:none;align-items:center;gap:1rem;padding:1.25rem 1.5rem;border-bottom:2px solid var(--primary-blue);margin-bottom:1rem}
</style>
<div class="instructor-layout">
    <%- include('../../partials/admin-sidebar', { activePage: 'logs' }) %>
    <main class="instructor-main">
        <div class="main-container">

            <!-- Print header -->
            <div class="print-report-header">
              <img src="/images/CSPC-logo.png" alt="CSPC" style="width:52px;height:52px;object-fit:contain;flex-shrink:0" onerror="this.style.display='none'">
              <div>
                <p style="font-size:.75rem;color:#6b7280;margin:0">Camarines Sur Polytechnic Colleges</p>
                <p style="font-size:.75rem;color:#6b7280;margin:0">College of Computer Studies</p>
                <h2 style="font-size:1.125rem;font-weight:700;color:#111827;margin:.25rem 0 0">Audit Logs Report</h2>
                <p style="font-size:.75rem;color:#6b7280;margin:.125rem 0 0">Generated by FaciTrack · Administrator View</p>
              </div>
            </div>

            <div class="page-header">
                <div>
                    <h1 class="page-title">Audit Logs</h1>
                    <p class="page-subtitle">Track all system activity, user access, and configuration changes.</p>
                </div>
                <div class="header-actions">
                    <button class="btn-header-action" id="btnExportLogs">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        Export PDF
                    </button>
                </div>
            </div>

            <!-- Stats -->
            <div class="stats-overview">
                <div class="stat-card-large confirmed">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Total Events</p>
                        <h2 class="stat-card-value"><%= logs.length %></h2>
                        <p class="stat-card-sublabel">All recorded events</p>
                    </div>
                </div>
                <div class="stat-card-large pending">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Logins Today</p>
                        <h2 class="stat-card-value"><%= logs.filter(l => l.type === 'login' && l.isToday).length %></h2>
                        <p class="stat-card-sublabel">Successful sign-ins</p>
                    </div>
                </div>
                <div class="stat-card-large workload">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Updates Today</p>
                        <h2 class="stat-card-value"><%= logs.filter(l => l.type === 'update' && l.isToday).length %></h2>
                        <p class="stat-card-sublabel">Configuration changes</p>
                    </div>
                </div>
                <div class="stat-card-large presence">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Events Today</p>
                        <h2 class="stat-card-value"><%= logs.filter(l => l.isToday).length %></h2>
                        <p class="stat-card-sublabel">Recorded this session</p>
                    </div>
                </div>
            </div>

            <!-- Table -->
            <div class="content-card">
                <div class="card-header">
                    <h3 class="card-title">All Events (<span id="visibleCount"><%= logs.length %></span>)</h3>
                </div>
                <%- include('../../partials/filter-bar', {
                  filterId: 'log',
                  searchPlaceholder: 'Search user or action…',
                  filterSections: [
                    { label: 'By Type', key: 'type', type: 'buttons',
                      items: [{ value:'', label:'All Types' }, { value:'login', label:'Login' },
                              { value:'logout', label:'Logout' }, { value:'update', label:'Update' },
                              { value:'create', label:'Create' }, { value:'delete', label:'Delete' }] },
                    { label: 'By Role', key: 'role', type: 'buttons',
                      items: [{ value:'', label:'All Roles' }, { value:'Admin', label:'Admin' },
                              { value:'Dean', label:'Dean' }, { value:'Instructor', label:'Instructor' }] }
                  ]
                }) %>
                <div class="card-body" style="padding:0;">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>User</th>
                                <th>Role</th>
                                <th>Action</th>
                                <th>Type</th>
                                <th>IP Address</th>
                                <th>Timestamp</th>
                            </tr>
                        </thead>
                        <tbody id="logsTableBody">
                            <% logs.forEach((log, i) => { %>
                            <tr data-type="<%= log.type %>" data-role="<%= log.role %>" data-user="<%= log.user.toLowerCase() %>" data-action="<%= log.action.toLowerCase() %>">
                                <td style="color:var(--gray-400);font-size:0.8125rem;"><%= i + 1 %></td>
                                <td>
                                    <div style="display:flex;align-items:center;gap:0.625rem;">
                                        <div class="apt-avatar-xs" style="width:34px;height:34px;font-size:0.6875rem;flex-shrink:0;"><%= log.user.split(' ').map(n=>n[0]).join('').slice(0,2) %></div>
                                        <span style="font-weight:600;font-size:0.875rem;color:var(--gray-900);"><%= log.user %></span>
                                    </div>
                                </td>
                                <td><span class="table-badge <%= log.role === 'Admin' ? 'workload' : log.role === 'Dean' ? 'pending' : 'confirmed' %>"><%= log.role %></span></td>
                                <td style="color:var(--gray-700);font-size:0.875rem;max-width:260px;"><%= log.action %></td>
                                <td>
                                    <span class="table-badge <%= log.type === 'login' || log.type === 'create' ? 'confirmed' : log.type === 'logout' || log.type === 'delete' ? 'declined' : 'pending' %>">
                                        <%= log.type.charAt(0).toUpperCase() + log.type.slice(1) %>
                                    </span>
                                </td>
                                <td style="color:var(--gray-500);font-size:0.8125rem;font-family:monospace;"><%= log.ip %></td>
                                <td style="color:var(--gray-500);font-size:0.8125rem;white-space:nowrap;"><%= log.timestamp %></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                    <div class="pagination-bar">
                        <span class="page-info" id="paginationInfo"></span>
                        <div class="pagination-controls" id="logPgCtrl"></div>
                    </div>
                </div>
            </div>

        </div>
    </main>
</div>

<div class="toast-container" id="toastContainer"></div>
<%- include('../../partials/footer') %>
<%- include('../../partials/script') %>
<script>
let currentPage = 1;
const rowsPerPage = 10;

function getAllRows() {
    return Array.from(document.querySelectorAll('#logsTableBody tr'));
}

let logFType = '', logFRole = '', logFSearch = '';

function applyFilters() {
    getAllRows().forEach(r => {
        const matchType   = !logFType   || r.dataset.type === logFType;
        const matchRole   = !logFRole   || r.dataset.role === logFRole;
        const matchSearch = !logFSearch || r.dataset.user.includes(logFSearch) || r.dataset.action.includes(logFSearch);
        r.dataset.filtered = (matchType && matchRole && matchSearch) ? 'show' : 'hide';
        r.style.display = 'none';
    });
    currentPage = 1;
    renderPage();
}

document.addEventListener('fbChange', function(e) {
    if (e.detail.filterId !== 'log') return;
    if (e.detail.section === 'type')   logFType = e.detail.value === '' ? '' : e.detail.value;
    if (e.detail.section === 'role')   logFRole = e.detail.value === '' ? '' : e.detail.value;
    applyFilters();
});
document.addEventListener('fbSearch', function(e) {
    if (e.detail.filterId !== 'log') return;
    logFSearch = e.detail.value.toLowerCase();
    applyFilters();
});

function getVisibleRows() {
    return getAllRows().filter(r => r.dataset.filtered !== 'hide');
}

function renderPage() {
    const rows = getVisibleRows();
    const total = rows.length;
    const totalPages = Math.max(1, Math.ceil(total / rowsPerPage));
    if (currentPage > totalPages) currentPage = totalPages;
    const start = (currentPage - 1) * rowsPerPage;
    const end = start + rowsPerPage;
    rows.forEach((r, i) => r.style.display = (i >= start && i < end) ? '' : 'none');
    document.getElementById('paginationInfo').textContent = total === 0 ? 'No results found' : `Showing ${Math.min(start+1,total)}–${Math.min(end,total)} of ${total}`;
    const ctrl = document.getElementById('logPgCtrl');
    ctrl.innerHTML = '';
    if (totalPages > 1) {
        const prev = document.createElement('button');
        prev.className = 'pg-btn pg-arrow';
        prev.innerHTML = '&#8592;';
        prev.disabled = currentPage === 1;
        prev.addEventListener('click', () => { currentPage--; renderPage(); });
        ctrl.appendChild(prev);

        let s = Math.max(1, currentPage - 2);
        let e = Math.min(totalPages, s + 4);
        s = Math.max(1, e - 4);
        for (let i = s; i <= e; i++) {
            const b = document.createElement('button');
            b.className = `pg-btn${i === currentPage ? ' active' : ''}`;
            b.textContent = i;
            b.addEventListener('click', () => { currentPage = i; renderPage(); });
            ctrl.appendChild(b);
        }

        const next = document.createElement('button');
        next.className = 'pg-btn pg-arrow';
        next.innerHTML = '&#8594;';
        next.disabled = currentPage >= totalPages;
        next.addEventListener('click', () => { currentPage++; renderPage(); });
        ctrl.appendChild(next);
    }
    document.getElementById('visibleCount').textContent = total;
}

function showToast(type, title, message) {
    const c = document.getElementById('toastContainer');
    const t = document.createElement('div');
    t.className = `toast ${type}`;
    t.innerHTML = `<div class="toast-content"><p class="toast-title">${title}</p><p class="toast-message">${message}</p></div>`;
    c.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 4000);
}

function createExportModal() {
    if(document.getElementById('exportLogsModal')) return;
    const modal = document.createElement('div');
    modal.id = 'exportLogsModal';
    modal.style.cssText = 'display:none;position:fixed;inset:0;z-index:2000;background:rgba(0,0,0,.6);align-items:center;justify-content:center;padding:1rem';
    modal.innerHTML = `
        <div style="background:#fff;border-radius:16px;width:100%;max-width:900px;height:90vh;display:flex;flex-direction:column;box-shadow:0 25px 70px rgba(0,0,0,.3);overflow:hidden">
            <div style="display:flex;align-items:center;justify-content:space-between;padding:1rem 1.5rem;border-bottom:1px solid var(--gray-100);background:var(--gray-50);flex-wrap:wrap;gap:1rem">
                <div>
                    <h3 style="font-size:1rem;font-weight:700;color:var(--gray-900);margin:0">Export Preview</h3>
                    <div style="font-size:.875rem;margin:0.75rem 0 0;display:flex;align-items:center;gap:.75rem">
                        <span>Destination:</span>
                        <div style="position:relative;display:inline-block;min-width:220px">
                            <button id="exportDestBtn" style="padding:.625rem .875rem;border:1px solid #e2e8f0;border-radius:6px;font-size:.875rem;background:#fff;display:flex;align-items:center;justify-content:space-between;cursor:pointer;color:#1f2937;width:100%">
                                <span id="exportDestText">Save as PDF</span>
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                            </button>
                            <div id="exportDestDropdown" style="position:absolute;top:100%;left:0;right:0;background:#fff;border:1px solid #e2e8f0;border-radius:6px;margin-top:.25rem;box-shadow:0 4px 12px rgba(0,0,0,.15);z-index:100;display:none;min-width:220px">
                                <button class="export-logs-item" data-value="pdf" style="display:block;width:100%;text-align:left;padding:.75rem 1rem;border:none;background:none;cursor:pointer;font-size:.875rem;color:#1f2937;transition:background .15s;border-bottom:1px solid #f3f4f6">Save as PDF</button>
                                <button class="export-logs-item" data-value="docx" style="display:block;width:100%;text-align:left;padding:.75rem 1rem;border:none;background:none;cursor:pointer;font-size:.875rem;color:#1f2937;transition:background .15s;border-bottom:1px solid #f3f4f6">Save as DOCX</button>
                                <button class="export-logs-item" data-value="xlsx" style="display:block;width:100%;text-align:left;padding:.75rem 1rem;border:none;background:none;cursor:pointer;font-size:.875rem;color:#1f2937;transition:background .15s">Save as XLSX</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div style="display:flex;gap:.75rem;flex-wrap:wrap">
                    <button id="exportLogsCancel" class="btn-page" style="height:36px;padding:0 1rem">Cancel</button>
                    <button id="exportLogsPrint" class="btn-header-action primary" style="height:36px;padding:0 1rem;font-size:.75rem">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:.4rem"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                        Export
                    </button>
                </div>
            </div>
            <div id="exportLogsScroll" style="flex:1;overflow-y:auto;padding:3rem;background:var(--gray-200);display:flex;justify-content:center">
                <div id="exportLogsArea" style="background:#fff;width:210mm;min-height:297mm;padding:20mm;box-shadow:0 0 20px rgba(0,0,0,.1);font-family:Arial,sans-serif;color:#000">
                    <!-- Dynamic content injected here -->
                </div>
            </div>
        </div>
    `;
    document.body.appendChild(modal);
}

let lastExportFormat = 'pdf';
let lastExportData = null;

function downloadExportLogs(format, title, columns, rows) {
    if(format === 'pdf'){
        window.print();
    } else if(format === 'docx' || format === 'xlsx'){
        const payload = { title: title, columns: columns, rows: rows };
        fetch('/export/' + format, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        }).then(function(res){
            if(!res.ok) throw new Error('Export failed');
            var dispo = res.headers.get('content-disposition') || '';
            var match = dispo.match(/filename="([^"]+)"/);
            var filename = match ? match[1] : title.replace(/[^\w\-]+/g,'_') + '.' + format;
            return res.blob().then(function(blob){
                var url = URL.createObjectURL(blob);
                var a = document.createElement('a');
                a.href = url;
                a.download = filename;
                document.body.appendChild(a);
                a.click();
                a.remove();
                setTimeout(function(){ URL.revokeObjectURL(url); }, 2500);
                document.getElementById('exportLogsModal').style.display = 'none';
            });
        }).catch(function(e){
            alert('Export failed: ' + e.message);
        });
    }
}

function showExportLogsModal(title, columns, rows) {
    createExportModal();
    lastExportData = { title, columns, rows };
    
    const modal = document.getElementById('exportLogsModal');
    const area = document.getElementById('exportLogsArea');
    const now = new Date().toLocaleString();
    
    let tableHtml = '<table style="width:100%;border-collapse:collapse;margin-top:20px;font-size:10pt">' +
        '<thead><tr style="background:#f3f4f6">' +
        columns.map(c => '<th style="border:1px solid #d1d5db;padding:8px;text-align:left">' + c + '</th>').join('') +
        '</tr></thead><tbody>';
    
    if(!rows.length){
        tableHtml += '<tr><td colspan="' + columns.length + '" style="border:1px solid #d1d5db;padding:20px;text-align:center;color:#6b7280">No data available for this report.</td></tr>';
    } else {
        rows.forEach(r => {
            tableHtml += '<tr>' + r.map(cell => '<td style="border:1px solid #d1d5db;padding:8px">' + cell + '</td>').join('') + '</tr>';
        });
    }
    tableHtml += '</tbody></table>';
    
    area.innerHTML = 
        '<div style="text-align:center;margin-bottom:30px;border-bottom:2px solid #000;padding-bottom:20px">' +
            '<div style="display:flex;align-items:center;justify-content:center;gap:15px;margin-bottom:10px">' +
                '<img src="/images/CSPC-logo.png" style="width:60px;height:60px" onerror="this.style.display=\'none\'">' +
                '<div style="text-align:left">' +
                    '<p style="margin:0;font-size:14pt;font-weight:700;text-transform:uppercase">Camarines Sur Polytechnic Colleges</p>' +
                    '<p style="margin:0;font-size:11pt">College of Computer Studies</p>' +
                    '<p style="margin:0;font-size:9pt;color:#4b5563">Nabua, Camarines Sur</p>' +
                '</div>' +
            '</div>' +
            '<h2 style="margin:20px 0 5px;font-size:16pt;text-decoration:underline">' + title + '</h2>' +
            '<p style="margin:0;font-size:10pt;color:#374151">Generated: ' + now + '</p>' +
        '</div>' +
        tableHtml +
        '<div style="margin-top:40px;display:flex;justify-content:space-between;font-size:10pt">' +
            '<div><p style="margin:0">System: FaciTrack v1.0</p></div>' +
        '</div>';
    
    modal.style.display = 'flex';
}

document.addEventListener('DOMContentLoaded', function(){
    createExportModal();
    
    const destBtn = document.getElementById('exportDestBtn');
    const destDropdown = document.getElementById('exportDestDropdown');
    const cancelBtn = document.getElementById('exportLogsCancel');
    const exportBtn = document.getElementById('exportLogsPrint');
    
    if(destBtn && destDropdown) {
        destBtn.addEventListener('click', e => {
            e.preventDefault();
            destDropdown.style.display = destDropdown.style.display === 'none' ? 'block' : 'none';
        });
        
        document.querySelectorAll('.export-logs-item').forEach(btn => {
            btn.addEventListener('click', e => {
                e.preventDefault();
                const format = e.target.dataset.value;
                const labels = { pdf: 'Save as PDF', docx: 'Save as DOCX', xlsx: 'Save as XLSX' };
                lastExportFormat = format;
                document.getElementById('exportDestText').textContent = labels[format];
                destDropdown.style.display = 'none';
            });
        });
        
        document.addEventListener('click', e => {
            if(destBtn && destDropdown && !destBtn.contains(e.target) && !destDropdown.contains(e.target)){
                destDropdown.style.display = 'none';
            }
        });
    }
    
    if(cancelBtn) {
        cancelBtn.addEventListener('click', () => {
            document.getElementById('exportLogsModal').style.display = 'none';
        });
    }
    
    if(exportBtn) {
        exportBtn.addEventListener('click', () => {
            if(!lastExportData) return;
            downloadExportLogs(lastExportFormat, lastExportData.title, lastExportData.columns, lastExportData.rows);
        });
    }
});

document.getElementById('btnExportLogs').addEventListener('click', function(e){
    e.preventDefault();
    const rows = getVisibleRows();
    const columns = ['Type', 'User', 'Action', 'Details', 'Timestamp'];
    const exportRows = rows.map(r => [
        r.dataset.type || '—',
        r.dataset.user || '—',
        r.dataset.action || '—',
        r.dataset.details || '—',
        r.dataset.timestamp || '—'
    ]);
    
    showExportLogsModal('Audit Logs Report', columns, exportRows);
});

getAllRows().forEach(r => r.dataset.filtered = 'show');
renderPage();
</script>
