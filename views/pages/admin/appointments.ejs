<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
@media print {
  .instructor-sidebar,.sidebar-footer,.header-actions,.stats-overview,.pagination-bar,.toast-container,.page-header,.filter-bar-container{display:none!important}
  .instructor-layout{display:block!important}
  .instructor-main{overflow:visible!important}
  .main-container{padding:0!important;gap:1rem!important}
  .content-card{box-shadow:none!important;border:1px solid #e5e7eb!important;break-inside:avoid}
  .report-header-block{padding:1rem 0!important;border:none!important;margin:0!important}
  .report-preview{margin:0!important;padding:0!important}
  .data-table{margin:0;padding:0;width:100%;border-collapse:collapse}
  .data-table td,.data-table th{padding:8px;border:1px solid #e5e7eb;font-size:11px}
  body{background:#fff!important}
}
</style>
<div class="instructor-layout">
    <%- include('../../partials/admin-sidebar', { activePage: 'appointments' }) %>

    <main class="instructor-main">
        <div class="main-container">

            <div class="page-header">
                <div>
                    <h1 class="page-title">Appointments</h1>
                    <p class="page-subtitle">Consultation appointments — College of Computer Studies</p>
                </div>
            </div>

            <div class="stats-overview">
                <div class="stat-card-large pending">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Pending</p>
                        <h2 class="stat-card-value"><%= allAppointments.filter(a => a.status === 'pending').length %></h2>
                        <p class="stat-card-sublabel">Awaiting response</p>
                    </div>
                </div>
                <div class="stat-card-large confirmed">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Confirmed</p>
                        <h2 class="stat-card-value"><%= allAppointments.filter(a => a.status === 'confirmed').length %></h2>
                        <p class="stat-card-sublabel">Scheduled</p>
                    </div>
                </div>
                <div class="stat-card-large presence">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Declined</p>
                        <h2 class="stat-card-value"><%= allAppointments.filter(a => a.status === 'declined').length %></h2>
                        <p class="stat-card-sublabel">Not approved</p>
                    </div>
                </div>
                <div class="stat-card-large workload">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Total</p>
                        <h2 class="stat-card-value"><%= allAppointments.length %></h2>
                        <p class="stat-card-sublabel">All appointments</p>
                    </div>
                </div>
            </div>

            <!-- Appointments Report -->
            <div class="content-card" style="overflow:visible">
                <div class="card-body">
                    <div class="report-preview">
                        <div class="report-header-block" style="display:flex;align-items:center;gap:1rem;text-align:left;padding:1.25rem 1.5rem">
                            <img src="/images/CSPC-logo.png" alt="CSPC" style="width:52px;height:52px;object-fit:contain;flex-shrink:0" onerror="this.style.display='none'">
                            <div>
                                <p class="report-institution">Camarines Sur Polytechnic Colleges</p>
                                <p class="report-college">College of Computer Studies</p>
                                <h4 class="report-title-block">Appointments Report</h4>
                                <p class="report-period">Filter: <span id="aptReportFilterText">All Appointments</span></p>
                            </div>
                            <div style="margin-left:auto;display:inline-block;position:relative">
                                <button class="btn-header-action primary" id="btnExportApt" style="height:36px;padding:0 1rem;font-size:.75rem;display:flex;align-items:center;gap:.4rem">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:.2rem"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                                    Export/Print
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6 9 12 15 18 9"/></svg>
                                </button>
                                <div class="dropdown-menu" id="exportAptDropdown" style="position:absolute;top:100%;right:0;background:#fff;border:1px solid #e5e7eb;border-radius:8px;margin-top:.5rem;min-width:150px;box-shadow:0 4px 12px rgba(0,0,0,.1);z-index:100;display:none">
                                    <button class="dropdown-item-apt" data-action="export" style="display:block;width:100%;text-align:left;padding:.75rem 1rem;border:none;background:none;cursor:pointer;font-size:.875rem;color:#374151;transition:background .15s">Export/Print</button>
                                </div>
                            </div>
                        </div>

                        <%- include('../../partials/filter-bar', {
                            filterId: 'apt',
                            searchPlaceholder: 'Search student or topic…',
                            filterSections: [
                                { label: 'By Faculty', key: 'instructor', type: 'buttons',
                                    items: [{ value:'all', label:'All Faculty' }].concat(faculty.map(function(f){ return { value: f.name, label: f.name }; })) },
                                { label: 'By Status', key: 'status', type: 'buttons',
                                    items: [{ value:'all', label:'All Status' }, { value:'pending', label:'Pending' },
                                            { value:'confirmed', label:'Confirmed' }, { value:'declined', label:'Declined' }] }
                            ]
                        }) %>

                        <div style="padding:0 1.5rem 1.5rem">
                            <div style="overflow-x:auto;margin-top:1rem">
                                <table class="data-table" id="appointmentsTable">
                                    <thead>
                                        <tr>
                                            <th>Student</th>
                                            <th>Faculty</th>
                                            <th>Date</th>
                                            <th>Time</th>
                                            <th>Topic</th>
                                            <th>Duration</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% allAppointments.forEach(apt => { %>
                                        <tr data-status="<%= apt.status %>" data-instructor="<%= apt.instructorName %>">
                                            <td>
                                                <div style="display:flex;align-items:center;gap:0.625rem">
                                                    <div class="apt-avatar-xs" style="width:34px;height:34px;font-size:0.6875rem;flex-shrink:0"><%= apt.studentName.split(' ').map(n=>n[0]).join('').slice(0,2) %></div>
                                                    <div style="min-width:0">
                                                        <div style="font-weight:600;font-size:0.875rem;color:var(--gray-900)"><%= apt.studentName %></div>
                                                        <div style="font-size:0.75rem;color:var(--gray-500)"><%= apt.studentId %></div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td style="font-size:0.875rem;color:var(--gray-700)"><%= apt.instructorName %></td>
                                            <td style="font-size:0.875rem;color:var(--gray-600)"><%= apt.date %></td>
                                            <td style="font-size:0.875rem;color:var(--gray-600)"><%= apt.time %></td>
                                            <td style="font-size:0.875rem;color:var(--gray-600);max-width:200px"><%= apt.topic %></td>
                                            <td style="font-size:0.875rem;color:var(--gray-600)"><%= apt.duration %></td>
                                            <td><span class="table-badge <%= apt.status %>"><%= apt.status.charAt(0).toUpperCase() + apt.status.slice(1) %></span></td>
                                        </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                            <div class="pagination-bar" id="aptReportPagBar">
                                <span class="page-info" id="aptReportPageInfo">-</span>
                                <div class="pagination-controls">
                                    <button class="btn-page" id="aptReportPrev" disabled>Prev</button>
                                    <button class="btn-page" id="aptReportNext" disabled>Next</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </main>
</div>

<div class="toast-container" id="toastContainer"></div>
<%- include('../../partials/footer') %>
<%- include('../../partials/script') %>
<script>
const ROWS_PER_PAGE = 5;
let aptPage = 1;
let aptFilterInstructor = 'all';
let aptFilterStatus = 'all';
let aptSearch = '';

function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

var ALL_APPOINTMENTS = <%- JSON.stringify(allAppointments) %>;
var FACULTY = <%- JSON.stringify(faculty) %>;

function filterAptRows(){
  var rows = ALL_APPOINTMENTS.slice();
  if(aptFilterInstructor !== 'all') rows = rows.filter(function(a){ return a.instructorName === aptFilterInstructor; });
  if(aptFilterStatus !== 'all') rows = rows.filter(function(a){ return a.status === aptFilterStatus; });
  if(aptSearch) rows = rows.filter(function(a){
    return a.studentName.toLowerCase().includes(aptSearch) || a.topic.toLowerCase().includes(aptSearch);
  });
  return rows;
}

var aptBody = document.getElementById('appointmentsTable').querySelector('tbody');
var aptPageInfo = document.getElementById('aptReportPageInfo');
var aptFilterText = document.getElementById('aptReportFilterText');

function renderAptTable(rows){
  var total = rows.length, pages = Math.max(1, Math.ceil(total / ROWS_PER_PAGE));
  if(aptPage > pages) aptPage = pages;
  var s = (aptPage - 1) * ROWS_PER_PAGE, slice = rows.slice(s, s + ROWS_PER_PAGE);
  aptBody.innerHTML = '';
  if(!slice.length){
    aptBody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--gray-400)">No appointments found.</td></tr>';
  } else {
    slice.forEach(function(apt){
      var tr = document.createElement('tr');
      tr.innerHTML = '<td><div style="display:flex;align-items:center;gap:0.625rem"><div class="apt-avatar-xs" style="width:34px;height:34px;font-size:0.6875rem;flex-shrink:0">'+esc(apt.studentName.split(' ').map(n=>n[0]).join('').slice(0,2))+'</div><div style="min-width:0"><div style="font-weight:600;font-size:0.875rem;color:var(--gray-900)">'+esc(apt.studentName)+'</div><div style="font-size:0.75rem;color:var(--gray-500)">'+esc(apt.studentId)+'</div></div></div></td>'
        +'<td style="font-size:0.875rem;color:var(--gray-700)">'+esc(apt.instructorName)+'</td>'
        +'<td style="font-size:0.875rem;color:var(--gray-600)">'+esc(apt.date)+'</td>'
        +'<td style="font-size:0.875rem;color:var(--gray-600)">'+esc(apt.time)+'</td>'
        +'<td style="font-size:0.875rem;color:var(--gray-600);max-width:200px">'+esc(apt.topic)+'</td>'
        +'<td style="font-size:0.875rem;color:var(--gray-600)">'+esc(apt.duration)+'</td>'
        +'<td><span class="table-badge '+apt.status+'">'+esc(apt.status.charAt(0).toUpperCase()+apt.status.slice(1))+'</span></td>';
      aptBody.appendChild(tr);
    });
  }
  aptPageInfo.textContent = total ? ('Showing '+(s+1)+'-'+Math.min(s+ROWS_PER_PAGE,total)+' of '+total) : 'No results';
  document.getElementById('aptReportPrev').disabled = aptPage <= 1;
  document.getElementById('aptReportNext').disabled = aptPage >= pages;
  updateAptFilter();
}

function updateAptFilter(){
  var parts = [];
  if(aptFilterInstructor !== 'all') parts.push('Faculty: '+aptFilterInstructor);
  if(aptFilterStatus !== 'all') parts.push('Status: '+{pending:'Pending',confirmed:'Confirmed',declined:'Declined'}[aptFilterStatus]);
  if(aptSearch) parts.push('Search: '+aptSearch);
  aptFilterText.textContent = parts.length > 0 ? parts.join(' · ') : 'All Appointments';
}

document.addEventListener('fbChange', function(e){
  if(e.detail.filterId !== 'apt') return;
  if(e.detail.section === 'instructor'){ aptFilterInstructor = e.detail.value||'all'; aptPage=1; }
  if(e.detail.section === 'status'){ aptFilterStatus = e.detail.value||'all'; aptPage=1; }
  renderAptTable(filterAptRows());
});

document.addEventListener('fbSearch', function(e){
  if(e.detail.filterId !== 'apt') return;
  aptSearch = e.detail.value.toLowerCase();
  aptPage = 1;
  renderAptTable(filterAptRows());
});

document.getElementById('aptReportPrev').addEventListener('click', function(){
  if(aptPage > 1){ aptPage--; renderAptTable(filterAptRows()); }
});
document.getElementById('aptReportNext').addEventListener('click', function(){
  var r = filterAptRows(), pages = Math.ceil(r.length / ROWS_PER_PAGE);
  if(aptPage < pages){ aptPage++; renderAptTable(r); }
});

document.getElementById('btnExportApt').addEventListener('click', function(){
  var dropdown = document.getElementById('exportAptDropdown');
  dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
});

document.querySelector('.dropdown-item-apt').addEventListener('click', function(){
  window.print();
});

renderAptTable(filterAptRows());
</script>
