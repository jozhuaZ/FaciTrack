                            </div>
                            <div style="margin-left:auto">
                                <button class="btn-header-action primary" id="btnExportAl" style="height:36px;padding:0 1rem;font-size:.75rem;display:flex;align-items:center;gap:.4rem" onclick="preparePrintReport(this)">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                                    Export/Print
                                </button>
                            </div>
                        </div>

                        <%- include('../../partials/filter-bar', {
                            filterId: 'al',
                            searchPlaceholder: 'Search user or action…',
