                                    items: [{ value:'all', label:'All Types' }, { value:'login', label:'Login' },
                                            { value:'logout', label:'Logout' }, { value:'update', label:'Update' },
                                            { value:'create', label:'Create' }, { value:'delete', label:'Delete' }] },
                                { label: 'By Role', key: 'role', type: 'buttons',
                                    items: [{ value:'all', label:'All Roles' }, { value:'Admin', label:'Admin' },
                                            { value:'Dean', label:'Dean' }, { value:'Instructor', label:'Instructor' }] }
                            ]
                        }) %>

                        <div style="padding:0 1.5rem 1.5rem">
                            <div style="overflow-x:auto;margin-top:1rem">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>User</th>
                                            <th>Role</th>
                                            <th>Action</th>
                                            <th>Type</th>
                                            <th>IP Address</th>
                                            <th>Timestamp</th>
                                        </tr>
                                    </thead>
                                    <tbody id="alReportBody"></tbody>
                                </table>
                            </div>
                            <div class="pagination-bar" id="alReportPagBar">
                                <span class="page-info" id="alReportPageInfo">-</span>
                                <div class="pagination-controls">
                                    <button class="btn-page" id="alReportPrev" disabled>Prev</button>
                                    <button class="btn-page" id="alReportNext" disabled>Next</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </main>
</div>

<div class="toast-container" id="toastContainer"></div>
<%- include('../../partials/footer') %>
<%- include('../../partials/script') %>
<script>
(function(){
  var FACULTY = <%- JSON.stringify(faculty) %>;
  var ALL_APPOINTMENTS = <%- JSON.stringify(allAppointments) %>;
  const PAGE = 10;

  function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
  function parseDate(v){ var d = new Date(v); return isNaN(d.getTime()) ? null : d; }
  function formatDate(v){ var d = parseDate(v); return d ? d.toLocaleDateString('en-PH', { month:'long', day:'numeric', year:'numeric' }) : '—'; }

  function weekRange(){
    var d=new Date(), s=new Date(d);
    s.setDate(d.getDate()-d.getDay());
    var e=new Date(s); e.setDate(s.getDate()+6);
    return {s:s, e:e};
  }
  function monthRange(){
    var d=new Date();
    return {s:new Date(d.getFullYear(),d.getMonth(),1), e:new Date(d.getFullYear(),d.getMonth()+1,0)};
  }

  // ===== Faculty Workload Report =====
  var fwPage = 1;
  var fwBody = document.getElementById('fwReportBody');
  var fwPageInfo = document.getElementById('fwReportPageInfo');

  function filterFwRows(){
    var rows = FACULTY.slice();
    return rows;
  }

  function renderFwTable(rows){
    var total=rows.length, pages=Math.max(1,Math.ceil(total/PAGE));
    if(fwPage>pages) fwPage=pages;
    var s=(fwPage-1)*PAGE, slice=rows.slice(s,s+PAGE);
    fwBody.innerHTML='';
    if(!slice.length){
      fwBody.innerHTML='<tr><td colspan="6" style="text-align:center;padding:2rem;color:var(--gray-400)">No faculty found.</td></tr>';
    } else {
      slice.forEach(function(f){
        var tr=document.createElement('tr');
        tr.innerHTML='<td><div style="display:flex;align-items:center;gap:.625rem"><div class="apt-avatar-xs" style="width:34px;height:34px;font-size:.6875rem;flex-shrink:0">'+esc(f.name.split(' ').map(n=>n[0]).join('').slice(0,2))+'</div><span style="font-weight:600;font-size:.875rem;color:var(--gray-900)">'+esc(f.name)+'</span></div></td>'
          +'<td style="font-size:.875rem;color:var(--gray-600)">'+esc(f.position)+'</td>'
          +'<td style="font-size:.875rem;color:var(--gray-600)">'+esc(f.department)+'</td>'
          +'<td style="text-align:center;font-weight:600;color:var(--gray-900)">'+esc(f.hoursThisMonth)+' hrs</td>'
          +'<td style="text-align:center"><span class="table-badge confirmed">'+esc(f.consultationsThisMonth)+'</span></td>'
          +'<td style="color:var(--gray-600)">'+esc(f.avgDuration)+'</td>';
        fwBody.appendChild(tr);
      });
    }
    fwPageInfo.textContent = total ? ('Showing '+(s+1)+'-'+Math.min(s+PAGE,total)+' of '+total) : 'No results';
    document.getElementById('fwReportPrev').disabled = fwPage<=1;
    document.getElementById('fwReportNext').disabled = fwPage>=pages;
  }

  // Filter handlers for Faculty Workload Report
  // No filters currently

  document.getElementById('fwReportPrev').addEventListener('click', function(){
    if(fwPage>1){ fwPage--; renderFwTable(filterFwRows()); }
  });
  document.getElementById('fwReportNext').addEventListener('click', function(){
    var r=filterFwRows(), pages=Math.ceil(r.length/PAGE);
    if(fwPage<pages){ fwPage++; renderFwTable(r); }
  });

  // ===== Consultation Logs Report =====
  var clPage = 1, clPeriod = 'all', clStatus = 'all';
  var clBody = document.getElementById('clReportBody');
  var clPageInfo = document.getElementById('clReportPageInfo');

  function filterClRows(){
    var rows = ALL_APPOINTMENTS.slice();
    if(clPeriod === 'week'){
      var r=weekRange();
      rows = rows.filter(function(a){ var d=new Date(a.date); return d>=r.s&&d<=r.e; });
    } else if(clPeriod === 'month'){
      var r2=monthRange();
      rows = rows.filter(function(a){ var d=new Date(a.date); return d>=r2.s&&d<=r2.e; });
    }
    if(clStatus !== 'all') rows = rows.filter(function(a){ return a.status===clStatus; });
    return rows;
  }

  function renderClTable(rows){
    var total=rows.length, pages=Math.max(1,Math.ceil(total/PAGE));
    if(clPage>pages) clPage=pages;
    var s=(clPage-1)*PAGE, slice=rows.slice(s,s+PAGE);
    clBody.innerHTML='';
    if(!slice.length){
      clBody.innerHTML='<tr><td colspan="6" style="text-align:center;padding:2rem;color:var(--gray-400)">No consultations found.</td></tr>';
    } else {
      slice.forEach(function(a){
        var sc=a.status.charAt(0).toUpperCase()+a.status.slice(1);
        var tr=document.createElement('tr');
        tr.innerHTML='<td><div><p style="font-weight:600;font-size:.875rem;color:var(--gray-900);margin:0">'+esc(a.studentName)+'</p><p style="font-size:.6875rem;color:var(--gray-400);margin:0">'+esc(a.studentId)+'</p></div></td>'
          +'<td style="font-size:.8125rem;color:var(--gray-700)">'+esc(a.instructorName)+'</td>'
          +'<td style="white-space:nowrap">'+esc(formatDate(a.date))+'</td>'
          +'<td style="white-space:nowrap">'+esc(a.time)+'</td>'
          +'<td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="'+esc(a.topic)+'">'+esc(a.topic)+'</td>'
          +'<td><span class="table-badge '+a.status+'">'+sc+'</span></td>';
        clBody.appendChild(tr);
      });
    }
    clPageInfo.textContent = total ? ('Showing '+(s+1)+'-'+Math.min(s+PAGE,total)+' of '+total) : 'No results';
    document.getElementById('clReportPrev').disabled = clPage<=1;
    document.getElementById('clReportNext').disabled = clPage>=pages;
  }

  // Filter handlers for Consultation Logs Report
  document.querySelectorAll('[data-filterid="cl"]').forEach(function(item){
    if(item.dataset.group){
      item.addEventListener('click', function(){
        if(item.dataset.group==='period'){ clPeriod=item.dataset.value||'all'; clPage=1; }
        else if(item.dataset.group==='status'){ clStatus=item.dataset.value||'all'; clPage=1; }
        renderClTable(filterClRows());
        document.getElementById('clReportPeriodText').textContent = {all:'All Records',week:'This Week',month:'This Month'}[clPeriod]||'All Records';
      });
    }
  });

  document.getElementById('clReportPrev').addEventListener('click', function(){
    if(clPage>1){ clPage--; renderClTable(filterClRows()); }
  });
  document.getElementById('clReportNext').addEventListener('click', function(){
    var r=filterClRows(), pages=Math.ceil(r.length/PAGE);
    if(clPage<pages){ clPage++; renderClTable(r); }
  });

  // ===== Audit Logs Report =====
  var LOGS = <%- JSON.stringify(logs) %>;
  var alPage = 1, alType = 'all', alRole = 'all', alSearch = '';
  var alBody = document.getElementById('alReportBody');
  var alPageInfo = document.getElementById('alReportPageInfo');
  var alFilterText = document.getElementById('alReportFilterText');

  function filterAlRows(){
    var rows = LOGS.slice();
    if(alType !== 'all') rows = rows.filter(function(l){ return l.type===alType; });
    if(alRole !== 'all') rows = rows.filter(function(l){ return l.role===alRole; });
    if(alSearch) rows = rows.filter(function(l){ 
      return l.user.toLowerCase().includes(alSearch) || l.action.toLowerCase().includes(alSearch);
    });
    return rows;
  }

  function renderAlTable(rows){
    var total=rows.length, pages=Math.max(1,Math.ceil(total/PAGE));
    if(alPage>pages) alPage=pages;
    var s=(alPage-1)*PAGE, slice=rows.slice(s,s+PAGE);
    alBody.innerHTML='';
    if(!slice.length){
      alBody.innerHTML='<tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--gray-400)">No audit logs found.</td></tr>';
    } else {
      slice.forEach(function(log, idx){
        var tr=document.createElement('tr');
        var badgeTypeClass = log.type==='login'||log.type==='create' ? 'confirmed' : log.type==='logout'||log.type==='delete' ? 'declined' : 'pending';
        var badgeRoleClass = log.role==='Admin' ? 'workload' : log.role==='Dean' ? 'pending' : 'confirmed';
        tr.innerHTML='<td style="color:var(--gray-400);font-size:0.8125rem">'+(s+idx+1)+'</td>'
          +'<td><div style="display:flex;align-items:center;gap:0.625rem"><div class="apt-avatar-xs" style="width:34px;height:34px;font-size:0.6875rem;flex-shrink:0">'+esc(log.user.split(' ').map(n=>n[0]).join('').slice(0,2))+'</div><span style="font-weight:600;font-size:0.875rem;color:var(--gray-900)">'+esc(log.user)+'</span></div></td>'
          +'<td><span class="table-badge '+badgeRoleClass+'">'+esc(log.role)+'</span></td>'
          +'<td style="color:var(--gray-700);font-size:0.875rem;max-width:260px">'+esc(log.action)+'</td>'
          +'<td><span class="table-badge '+badgeTypeClass+'">'+esc(log.type.charAt(0).toUpperCase()+log.type.slice(1))+'</span></td>'
          +'<td style="color:var(--gray-500);font-size:0.8125rem;font-family:monospace">'+esc(log.ip)+'</td>'
          +'<td style="color:var(--gray-500);font-size:0.8125rem;white-space:nowrap">'+esc(log.timestamp)+'</td>';
        alBody.appendChild(tr);
      });
    }
    alPageInfo.textContent = total ? ('Showing '+(s+1)+'-'+Math.min(s+PAGE,total)+' of '+total) : 'No results';
    document.getElementById('alReportPrev').disabled = alPage<=1;
    document.getElementById('alReportNext').disabled = alPage>=pages;
    updateAlFilter();
  }

  function updateAlFilter(){
    var parts = [];
    if(alType !== 'all') parts.push('Type: '+{login:'Login',logout:'Logout',update:'Update',create:'Create',delete:'Delete'}[alType]);
    if(alRole !== 'all') parts.push('Role: '+alRole);
    if(alSearch) parts.push('Search: '+alSearch);
    alFilterText.textContent = parts.length > 0 ? parts.join(' · ') : 'All Events';
  }

  // Filter handlers for Audit Logs Report
  document.addEventListener('fbChange', function(e){
    if(e.detail.filterId !== 'al') return;
    if(e.detail.section === 'type'){ alType = e.detail.value||'all'; alPage=1; }
    if(e.detail.section === 'role'){ alRole = e.detail.value||'all'; alPage=1; }
    renderAlTable(filterAlRows());
  });

  document.addEventListener('fbSearch', function(e){
    if(e.detail.filterId !== 'al') return;
    alSearch = e.detail.value.toLowerCase();
    alPage = 1;
    renderAlTable(filterAlRows());
  });

  document.getElementById('alReportPrev').addEventListener('click', function(){
    if(alPage>1){ alPage--; renderAlTable(filterAlRows()); }
  });
  document.getElementById('alReportNext').addEventListener('click', function(){
    var r=filterAlRows(), pages=Math.ceil(r.length/PAGE);
    if(alPage<pages){ alPage++; renderAlTable(r); }
  });

  // Initial render
  renderFwTable(filterFwRows());
  renderClTable(filterClRows());
  renderAlTable(filterAlRows());
}());

function preparePrintReport(item){
  var preview = item.closest('.report-preview');
  if(!preview) return;
  preview.querySelectorAll('.report-header-block').forEach(function(hdr){
    var existing = hdr.querySelector('.print-header-inner');
    if(existing) existing.remove();
    var titleEl    = hdr.querySelector('.report-title-block');
    var subtitleEl = hdr.querySelector('.report-subtitle');
    var periodEl   = hdr.querySelector('.report-period');
    var imgEl      = hdr.querySelector('img');
    var title    = titleEl    ? titleEl.textContent.trim()    : '';
    var subtitle = subtitleEl ? subtitleEl.textContent.trim() : '';
    var period   = periodEl   ? periodEl.innerText.trim()     : '';
    var imgSrc   = imgEl      ? imgEl.src                     : '/images/CSPC-logo.png';
    var inner = document.createElement('div');
    inner.className = 'print-header-inner';
    inner.innerHTML =
      '<img src="'+imgSrc+'" alt="CSPC Logo">' +
      '<div class="print-header-text">' +
        '<span class="ph-republic">Republic of the Philippines</span>' +
        '<span class="ph-institution">Camarines Sur Polytechnic Colleges</span>' +
        '<span class="ph-address">Nabua, Camarines Sur</span>' +
        '<span class="ph-title">'+title+'</span>' +
        '<span class="ph-subtitle">'+subtitle+'</span>' +
        (period ? '<span class="ph-period">'+period+'</span>' : '') +
      '</div>';
    hdr.appendChild(inner);
  });
  document.querySelectorAll('.report-preview.print-only').forEach(function(c){ c.classList.remove('print-only'); });
  preview.classList.add('print-only');
  document.body.classList.add('print-mode');
  setTimeout(function(){
    window.print();
    setTimeout(function(){
      preview.classList.remove('print-only');
      document.body.classList.remove('print-mode');
      preview.querySelectorAll('.print-header-inner').forEach(function(el){ el.remove(); });
    }, 500);
  }, 50);
}
</script>
