<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
@media print{
  @page{size:A4 portrait;margin:1.5cm}
  *{box-sizing:border-box!important;-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important}
  html,body{width:100%!important;height:auto!important;margin:0!important;padding:0!important;background:#fff!important;color:#000!important;font-family:'Arial','Helvetica',sans-serif!important}
  body.print-mode .report-preview:not(.print-only){display:none!important}
  .instructor-layout,.instructor-main,.main-container{width:100%!important;margin:0!important;padding:0!important;display:block!important;overflow:visible!important}
  .instructor-sidebar,.sidebar-footer,.header-actions,.stats-overview,.pagination-bar,.toast-container,.page-header,.filter-bar-container,.fb-bar,.fb-filter-menu,.dropdown-menu,.btn-header-action,.main-header{display:none!important}
  .content-card{box-shadow:none!important;border:none!important;border-radius:0!important;background:#fff!important;margin:0!important;padding:0!important}
  .card-header,.card-body{padding:0!important;margin:0!important;background:transparent!important;border:none!important;box-shadow:none!important}
  .report-preview{display:block!important;margin:0!important;padding:0!important;width:100%!important}
  .report-preview.print-only{display:block!important}
  .report-preview + .report-preview{page-break-before:always!important}
  /* ── Official CSPC Letterhead Header ── */
  .report-header-block{display:block!important;width:100%!important;border-bottom:2.5pt solid #000!important;padding:0 0 0.3cm 0!important;margin:0 0 0.4cm 0!important;position:relative!important;overflow:visible!important}
  .report-header-block::before{content:'CSPC-F-STA-01';display:block!important;font-size:7pt!important;font-weight:700!important;text-align:right!important;position:absolute!important;top:0!important;right:0!important;font-family:'Arial',sans-serif!important}
  .report-header-block > *{display:none!important}
  .report-header-block > .print-header-inner{display:flex!important;align-items:center!important;gap:0.4cm!important;padding-top:0.2cm!important}
  .report-header-block > .print-header-inner > img{width:1.4cm!important;height:1.4cm!important;object-fit:contain!important;flex-shrink:0!important;display:block!important}
  .report-header-block > .print-header-inner > .print-header-text{flex:1!important;text-align:center!important;display:block!important}
  .print-header-inner .ph-republic{display:block!important;font-size:7.5pt!important;font-weight:400!important;font-style:italic!important;text-align:center!important;margin:0!important;line-height:1.4!important}
  .print-header-inner .ph-institution{display:block!important;font-size:13pt!important;font-weight:900!important;text-transform:uppercase!important;text-align:center!important;letter-spacing:0.03em!important;margin:0.04cm 0 0!important;line-height:1.2!important}
  .print-header-inner .ph-address{display:block!important;font-size:8pt!important;text-align:center!important;margin:0.02cm 0 0.12cm!important;line-height:1.3!important}
  .print-header-inner .ph-title{display:block!important;font-size:13pt!important;font-weight:800!important;text-transform:uppercase!important;text-align:center!important;text-decoration:underline!important;letter-spacing:0.04em!important;margin:0.12cm 0 0.04cm!important;line-height:1.2!important}
  .print-header-inner .ph-subtitle{display:block!important;font-size:9pt!important;font-weight:600!important;text-align:center!important;margin:0 0 0.04cm!important}
  .print-header-inner .ph-period{display:block!important;font-size:8pt!important;text-align:center!important;margin:0.04cm 0 0!important;color:#333!important}
  /* ── Table ── */
  div[style*="padding:0 1.5rem"]{padding:0!important}
  div[style*="overflow-x:auto"]{overflow:visible!important}
  .pagination-bar,button{display:none!important}
  .data-table{margin:0!important;padding:0!important;width:100%!important;border-collapse:collapse!important;font-family:'Arial',sans-serif!important;font-size:8.5pt!important}
  .data-table th{background:#e8e8e8!important;border:1pt solid #000!important;padding:0.18cm 0.2cm!important;font-weight:700!important;text-align:left!important;vertical-align:middle!important}
  .data-table td{border:1pt solid #000!important;padding:0.15cm 0.2cm!important;text-align:left!important;vertical-align:top!important}
  .data-table tr:nth-child(even) td{background:#f5f5f5!important}
  .table-badge{background:none!important;border:none!important;padding:0!important;font-weight:700!important;font-size:8pt!important;color:#000!important}
  .apt-avatar-xs{display:none!important}
  .section-divider{border-top:1px solid #000!important;margin:0.3cm 0!important}
}
</style>

<div class="instructor-layout">
    <%- include('../../partials/admin-sidebar', { activePage: 'reports' }) %>
    <main class="instructor-main">
        <div class="main-container">

            <div class="page-header">
                <div>
                    <h1 class="page-title">Reports</h1>
                    <p class="page-subtitle">Faculty workload, consultation logs, and system audit records — College of Computer Studies</p>
                </div>
            </div>

            <!-- Stats -->
            <div class="stats-overview">
                <div class="stat-card-large confirmed">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Total Faculty</p>
                        <h2 class="stat-card-value"><%= faculty.length %></h2>
                        <p class="stat-card-sublabel">CCS Department</p>
                    </div>
                </div>
                <div class="stat-card-large pending">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Consultations This Month</p>
                        <h2 class="stat-card-value"><%= allAppointments.filter(a => a.status === 'confirmed').length %></h2>
                        <p class="stat-card-sublabel">Completed sessions</p>
                    </div>
                </div>
                <div class="stat-card-large workload">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Total Hours Logged</p>
                        <h2 class="stat-card-value"><%= (faculty.reduce((s,f) => s + (f.hoursThisMonth||0), 0)).toFixed(0) %></h2>
                        <p class="stat-card-sublabel">This month</p>
                    </div>
                </div>
                <div class="stat-card-large presence">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Average Duration</p>
                        <h2 class="stat-card-value">42<span style="font-size:0.6em;margin-left:0.25rem">min</span></h2>
                        <p class="stat-card-sublabel">Per consultation</p>
                    </div>
                </div>
            </div>

            <!-- Faculty Workload Report -->
