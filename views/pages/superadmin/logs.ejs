<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
.log-badge{display:inline-flex;padding:.2rem .6rem;border-radius:999px;font-size:.65rem;font-weight:700}
.log-badge.login    {background:rgba(22,163,74,.12);color:#15803d}
.log-badge.logout   {background:rgba(107,114,128,.12);color:#374151}
.log-badge.update   {background:rgba(234,179,8,.12);color:#92400e}
.log-badge.create   {background:rgba(10,61,98,.1);color:var(--primary-blue)}
.log-badge.delete   {background:rgba(220,38,38,.1);color:#dc2626}

/* Print / PDF export styles */
@media print {
  .instructor-sidebar, .sidebar-footer, .header-actions,
  .stats-overview, .card-header .modal-select,
  .pagination-bar, .toast-container { display:none!important; }
  .instructor-layout { display:block!important; }
  .instructor-main { overflow:visible!important; }
  .main-container { padding:0!important; gap:1rem!important; }
  .content-card { box-shadow:none!important; border:1px solid #e5e7eb!important; break-inside:avoid; }
  .print-report-header { display:flex!important; }
  body { background:#fff!important; }
}
.print-report-header {
  display:none;
  align-items:center;
  gap:1rem;
  padding:1.25rem 1.5rem;
  border-bottom:2px solid var(--primary-blue);
  margin-bottom:1rem;
}
</style>

<div class="instructor-layout">
  <%- include('../../partials/superadmin-sidebar', { activePage: 'logs' }) %>
  <main class="instructor-main">
    <div class="main-container">

      <!-- Print header (hidden on screen, shown on print) -->
      <div class="print-report-header">
        <img src="/images/CSPC-logo.png" alt="CSPC" style="width:52px;height:52px;object-fit:contain;flex-shrink:0" onerror="this.style.display='none'">
        <div>
          <p style="font-size:.75rem;color:#6b7280;margin:0">Camarines Sur Polytechnic Colleges</p>
          <p style="font-size:.75rem;color:#6b7280;margin:0">Office of the Super Administrator</p>
          <h2 style="font-size:1.125rem;font-weight:700;color:#111827;margin:.25rem 0 0">Audit Logs Report</h2>
          <p style="font-size:.75rem;color:#6b7280;margin:.125rem 0 0">Generated by FaciTrack · Super Administrator View</p>
        </div>
      </div>

      <div class="page-header">
        <div>
          <h1 class="page-title">Audit Logs</h1>
          <p class="page-subtitle">System-wide activity log — all user actions across CSPC</p>
        </div>
        <div class="header-actions">
          <button class="btn-header-action" id="btnExport">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Export PDF
          </button>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats-overview">
        <div class="stat-card-large confirmed">
          <div class="stat-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
          <div class="stat-card-content">
            <p class="stat-card-label">Total Events</p>
            <h2 class="stat-card-value"><%= logs.length %></h2>
            <p class="stat-card-sublabel">All recorded actions</p>
          </div>
        </div>
        <div class="stat-card-large workload">
          <div class="stat-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
          <div class="stat-card-content">
            <p class="stat-card-label">Today's Events</p>
            <h2 class="stat-card-value"><%= logs.filter(l=>l.isToday).length %></h2>
            <p class="stat-card-sublabel">Logged today</p>
          </div>
        </div>
      </div>

      <div class="content-card">
        <div class="card-header">
          <h3 class="card-title">Activity Log (<span id="logCount"><%= logs.length %></span>)</h3>
        </div>
        <%- include('../../partials/filter-bar', {
          filterId: 'saLog',
          searchPlaceholder: 'Search user or action…',
          filterSections: [
            { label: 'By Type', key: 'type', type: 'buttons',
              items: [{ value:'', label:'All Types' }, { value:'login', label:'Login' },
                      { value:'logout', label:'Logout' }, { value:'update', label:'Update' },
                      { value:'create', label:'Create' }, { value:'delete', label:'Delete' }] },
            { label: 'By Role', key: 'role', type: 'buttons',
              items: [{ value:'', label:'All Roles' }, { value:'Instructor', label:'Instructor' },
                      { value:'Dean', label:'Dean' }, { value:'Admin', label:'Admin' }] }
          ]
        }) %>
        <div class="card-body" style="padding:0">
          <div style="overflow-x:auto">
            <table class="data-table" id="logTbl">
              <thead><tr><th>User</th><th>Role</th><th>Action</th><th>Type</th><th>IP Address</th><th>Timestamp</th></tr></thead>
              <tbody>
                <% logs.forEach(l => { %>
                <tr data-type="<%= l.type %>" data-role="<%= l.role %>">
                  <td style="font-weight:600;font-size:.875rem"><%= l.user %></td>
                  <td><span class="table-badge <%= l.role==='Admin'?'workload':l.role==='Dean'?'pending':'confirmed' %>"><%= l.role==='Admin'?'Sub-Admin':l.role %></span></td>
                  <td style="font-size:.8125rem;color:var(--gray-700)"><%= l.action %></td>
                  <td><span class="log-badge <%= l.type %>"><%= l.type %></span></td>
                  <td style="font-size:.78rem;color:var(--gray-400)"><%= l.ip %></td>
                  <td style="font-size:.78rem;color:var(--gray-500);white-space:nowrap"><%= l.timestamp %></td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
          <div class="pagination-bar">
            <span class="page-info" id="logPageInfo">—</span>
            <div class="pagination-controls" id="logPgCtrl"></div>
          </div>
        </div>
      </div>

    </div>
  </main>
</div>
<div class="toast-container" id="toastContainer"></div>
<%- include('../../partials/footer') %>
<%- include('../../partials/script') %>
<script>
(function(){
  'use strict';
  var ROWS=10, page=1;
  var saLogFType='', saLogFRole='', saLogFSearch='';

  function allRows(){ return Array.from(document.querySelectorAll('#logTbl tbody tr')); }

  function visible(){
    return allRows().filter(function(row){
      return (!saLogFType||row.dataset.type===saLogFType)
          && (!saLogFRole||row.dataset.role===saLogFRole)
          && (!saLogFSearch||row.dataset.user.toLowerCase().includes(saLogFSearch)||row.dataset.action.toLowerCase().includes(saLogFSearch));
    });
  }

  document.addEventListener('fbChange',function(e){
    if(e.detail.filterId!=='saLog') return;
    if(e.detail.section==='type') saLogFType=e.detail.value;
    if(e.detail.section==='role') saLogFRole=e.detail.value;
    page=1; render();
  });
  document.addEventListener('fbSearch',function(e){
    if(e.detail.filterId!=='saLog') return;
    saLogFSearch=e.detail.value.toLowerCase();
    page=1; render();
  });

  function render(){
    var vis=visible(), total=vis.length, pages=Math.max(1,Math.ceil(total/ROWS));
    if(page>pages) page=pages;
    allRows().forEach(function(r){r.style.display='none';});
    vis.slice((page-1)*ROWS,page*ROWS).forEach(function(r){r.style.display='';});
    document.getElementById('logCount').textContent=total;
    var from=total?(page-1)*ROWS+1:0, to=Math.min(page*ROWS,total);
    document.getElementById('logPageInfo').textContent=total?('Showing '+from+'–'+to+' of '+total):'No results';
    var ctrl=document.getElementById('logPgCtrl'); ctrl.innerHTML='';
    if(pages<=1) return;
    var prev=document.createElement('button');
    prev.className='pg-btn pg-arrow'; prev.innerHTML='&#8592;'; prev.disabled=page===1;
    prev.addEventListener('click',function(){page--;render();}); ctrl.appendChild(prev);
    var s=Math.max(1,page-2),e=Math.min(pages,s+4); s=Math.max(1,e-4);
    for(var i=s;i<=e;i++){
      var b=document.createElement('button');
      b.className='pg-btn'+(i===page?' active':'');
      b.textContent=i;
      (function(pg){b.addEventListener('click',function(){page=pg;render();});})(i);
      ctrl.appendChild(b);
    }
    var next=document.createElement('button');
    next.className='pg-btn pg-arrow'; next.innerHTML='&#8594;'; next.disabled=page>=pages;
    next.addEventListener('click',function(){page++;render();}); ctrl.appendChild(next);
  }

  function applyF(){ page=1; render(); }
  window.applyF=applyF;

  // Create export modal
  function createSuperExportModal() {
    if(document.getElementById('superExportLogsModal')) return;
    const modal = document.createElement('div');
    modal.id = 'superExportLogsModal';
    modal.style.cssText = 'display:none;position:fixed;inset:0;z-index:2000;background:rgba(0,0,0,.6);align-items:center;justify-content:center;padding:1rem';
    modal.innerHTML = `
        <div style="background:#fff;border-radius:16px;width:100%;max-width:900px;height:90vh;display:flex;flex-direction:column;box-shadow:0 25px 70px rgba(0,0,0,.3);overflow:hidden">
            <div style="display:flex;align-items:center;justify-content:space-between;padding:1rem 1.5rem;border-bottom:1px solid var(--gray-100);background:var(--gray-50);flex-wrap:wrap;gap:1rem">
                <div>
                    <h3 style="font-size:1rem;font-weight:700;color:var(--gray-900);margin:0">Export Preview</h3>
                    <div style="font-size:.875rem;margin:0.75rem 0 0;display:flex;align-items:center;gap:.75rem">
                        <span>Destination:</span>
                        <div style="position:relative;display:inline-block;min-width:220px">
                            <button id="superExportDestBtn" style="padding:.625rem .875rem;border:1px solid #e2e8f0;border-radius:6px;font-size:.875rem;background:#fff;display:flex;align-items:center;justify-content:space-between;cursor:pointer;color:#1f2937;width:100%">
                                <span id="superExportDestText">Save as PDF</span>
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                            </button>
                            <div id="superExportDestDropdown" style="position:absolute;top:100%;left:0;right:0;background:#fff;border:1px solid #e2e8f0;border-radius:6px;margin-top:.25rem;box-shadow:0 4px 12px rgba(0,0,0,.15);z-index:100;display:none;min-width:220px">
                                <button class="super-export-item" data-value="pdf" style="display:block;width:100%;text-align:left;padding:.75rem 1rem;border:none;background:none;cursor:pointer;font-size:.875rem;color:#1f2937;transition:background .15s;border-bottom:1px solid #f3f4f6">Save as PDF</button>
                                <button class="super-export-item" data-value="docx" style="display:block;width:100%;text-align:left;padding:.75rem 1rem;border:none;background:none;cursor:pointer;font-size:.875rem;color:#1f2937;transition:background .15s;border-bottom:1px solid #f3f4f6">Save as DOCX</button>
                                <button class="super-export-item" data-value="xlsx" style="display:block;width:100%;text-align:left;padding:.75rem 1rem;border:none;background:none;cursor:pointer;font-size:.875rem;color:#1f2937;transition:background .15s">Save as XLSX</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div style="display:flex;gap:.75rem;flex-wrap:wrap">
                    <button id="superExportLogsCancel" class="btn-page" style="height:36px;padding:0 1rem">Cancel</button>
                    <button id="superExportLogsPrint" class="btn-header-action primary" style="height:36px;padding:0 1rem;font-size:.75rem">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:.4rem"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                        Export
                    </button>
                </div>
            </div>
            <div id="superExportLogsScroll" style="flex:1;overflow-y:auto;padding:3rem;background:var(--gray-200);display:flex;justify-content:center">
                <div id="superExportLogsArea" style="background:#fff;width:210mm;min-height:297mm;padding:20mm;box-shadow:0 0 20px rgba(0,0,0,.1);font-family:Arial,sans-serif;color:#000">
                    <!-- Dynamic content injected here -->
                </div>
            </div>
        </div>
    `;
    document.body.appendChild(modal);
  }

  let superLastExportFormat = 'pdf';
  let superLastExportData = null;

  function downloadSuperExportLogs(format, title, columns, rows) {
    if(format === 'pdf'){
      window.print();
    } else if(format === 'docx' || format === 'xlsx'){
      const payload = { title: title, columns: columns, rows: rows };
      fetch('/export/' + format, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      }).then(function(res){
        if(!res.ok) throw new Error('Export failed');
        var dispo = res.headers.get('content-disposition') || '';
        var match = dispo.match(/filename="([^"]+)"/);
        var filename = match ? match[1] : title.replace(/[^\w\-]+/g,'_') + '.' + format;
        return res.blob().then(function(blob){
          var url = URL.createObjectURL(blob);
          var a = document.createElement('a');
          a.href = url;
          a.download = filename;
          document.body.appendChild(a);
          a.click();
          a.remove();
          setTimeout(function(){ URL.revokeObjectURL(url); }, 2500);
          document.getElementById('superExportLogsModal').style.display = 'none';
        });
      }).catch(function(e){
        alert('Export failed: ' + e.message);
      });
    }
  }

  function showSuperExportLogsModal(title, columns, rows) {
    createSuperExportModal();
    superLastExportData = { title, columns, rows };
    
    const modal = document.getElementById('superExportLogsModal');
    const area = document.getElementById('superExportLogsArea');
    const now = new Date().toLocaleString();
    
    let tableHtml = '<table style="width:100%;border-collapse:collapse;margin-top:20px;font-size:10pt">' +
        '<thead><tr style="background:#f3f4f6">' +
        columns.map(c => '<th style="border:1px solid #d1d5db;padding:8px;text-align:left">' + c + '</th>').join('') +
        '</tr></thead><tbody>';
    
    if(!rows.length){
      tableHtml += '<tr><td colspan="' + columns.length + '" style="border:1px solid #d1d5db;padding:20px;text-align:center;color:#6b7280">No data available for this report.</td></tr>';
    } else {
      rows.forEach(r => {
        tableHtml += '<tr>' + r.map(cell => '<td style="border:1px solid #d1d5db;padding:8px">' + cell + '</td>').join('') + '</tr>';
      });
    }
    tableHtml += '</tbody></table>';
    
    area.innerHTML = 
        '<div style="text-align:center;margin-bottom:30px;border-bottom:2px solid #000;padding-bottom:20px">' +
            '<div style="display:flex;align-items:center;justify-content:center;gap:15px;margin-bottom:10px">' +
                '<img src="/images/CSPC-logo.png" style="width:60px;height:60px" onerror="this.style.display=\'none\'">' +
                '<div style="text-align:left">' +
                    '<p style="margin:0;font-size:14pt;font-weight:700;text-transform:uppercase">Camarines Sur Polytechnic Colleges</p>' +
                    '<p style="margin:0;font-size:11pt">College of Computer Studies</p>' +
                    '<p style="margin:0;font-size:9pt;color:#4b5563">Nabua, Camarines Sur</p>' +
                '</div>' +
            '</div>' +
            '<h2 style="margin:20px 0 5px;font-size:16pt;text-decoration:underline">' + title + '</h2>' +
            '<p style="margin:0;font-size:10pt;color:#374151">Generated: ' + now + '</p>' +
        '</div>' +
        tableHtml +
        '<div style="margin-top:40px;display:flex;justify-content:space-between;font-size:10pt">' +
            '<div><p style="margin:0">System: FaciTrack v1.0</p></div>' +
        '</div>';
    
    modal.style.display = 'flex';
  }

  // Initialize modal handlers on load
  document.addEventListener('DOMContentLoaded', function(){
    createSuperExportModal();
    
    const destBtn = document.getElementById('superExportDestBtn');
    const destDropdown = document.getElementById('superExportDestDropdown');
    const cancelBtn = document.getElementById('superExportLogsCancel');
    const exportBtn = document.getElementById('superExportLogsPrint');
    
    if(destBtn && destDropdown) {
      destBtn.addEventListener('click', e => {
        e.preventDefault();
        destDropdown.style.display = destDropdown.style.display === 'none' ? 'block' : 'none';
      });
      
      document.querySelectorAll('.super-export-item').forEach(btn => {
        btn.addEventListener('click', e => {
          e.preventDefault();
          const format = e.target.dataset.value;
          const labels = { pdf: 'Save as PDF', docx: 'Save as DOCX', xlsx: 'Save as XLSX' };
          superLastExportFormat = format;
          document.getElementById('superExportDestText').textContent = labels[format];
          destDropdown.style.display = 'none';
        });
      });
      
      document.addEventListener('click', e => {
        if(destBtn && destDropdown && !destBtn.contains(e.target) && !destDropdown.contains(e.target)){
          destDropdown.style.display = 'none';
        }
      });
    }
    
    if(cancelBtn) {
      cancelBtn.addEventListener('click', () => {
        document.getElementById('superExportLogsModal').style.display = 'none';
      });
    }
    
    if(exportBtn) {
      exportBtn.addEventListener('click', () => {
        if(!superLastExportData) return;
        downloadSuperExportLogs(superLastExportFormat, superLastExportData.title, superLastExportData.columns, superLastExportData.rows);
      });
    }
  });

  // Export Preview → Save PDF/DOCX/XLSX or Print
  document.getElementById('btnExport').addEventListener('click',function(e){
    e.preventDefault();
    const rows = allRows().filter(r => r.style.display !== 'none');
    const columns = ['User', 'Role', 'Action', 'Type', 'IP Address', 'Timestamp'];
    const exportRows = rows.map(r => {
      const cells = r.querySelectorAll('td');
      return [
        cells[0]?.textContent.trim() || '—',
        cells[1]?.textContent.trim() || '—',
        cells[2]?.textContent.trim() || '—',
        cells[3]?.textContent.trim() || '—',
        cells[4]?.textContent.trim() || '—',
        cells[5]?.textContent.trim() || '—'
      ];
    });
    showSuperExportLogsModal('Audit Logs Report', columns, exportRows);
  });

  render();
}());
</script>
