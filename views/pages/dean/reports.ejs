<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
.period-filter-bar{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap}
.period-pill{padding:.5rem 1.125rem;border:1.5px solid var(--gray-200);border-radius:999px;background:#fff;font-size:.8125rem;font-weight:600;color:var(--gray-600);cursor:pointer;transition:all .2s;font-family:var(--font-body)}
.period-pill:hover{border-color:var(--primary-blue);color:var(--primary-blue)}
.period-pill.active{background:var(--primary-blue);border-color:var(--primary-blue);color:#fff}
#customDateInput{display:none;padding:.45rem .875rem;border:1.5px solid var(--gray-200);border-radius:999px;font-size:.8125rem;font-family:var(--font-body);color:var(--gray-800);background:#fff;outline:none}
.faculty-select{padding:.45rem .875rem;border:1.5px solid var(--gray-200);border-radius:999px;font-size:.8125rem;font-family:var(--font-body);color:var(--gray-800);background:#fff;outline:none;cursor:pointer}
.faculty-select:focus{border-color:var(--primary-blue)}
.analytics-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
@media(max-width:900px){.analytics-grid{grid-template-columns:1fr}}
@media print{
  @page{size:A4 portrait;margin:1.5cm}
  *{box-sizing:border-box!important;-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important}
  html,body{width:100%!important;height:auto!important;margin:0!important;padding:0!important;background:#fff!important;color:#000!important;font-family:'Arial','Helvetica',sans-serif!important}
  body.print-mode .report-preview:not(.print-only){display:none!important}
  .instructor-layout,.instructor-main,.main-container{width:100%!important;margin:0!important;padding:0!important;display:block!important;overflow:visible!important}
  .dean-sidebar,.sidebar-footer,.header-actions,.stats-overview,.toast-container,.page-header,.analytics-grid,.filter-bar-container,.fb-bar,.fb-filter-menu,.dropdown-menu,.btn-header-action,.main-header{display:none!important}
  .content-card{box-shadow:none!important;border:none!important;border-radius:0!important;background:#fff!important;margin:0!important;padding:0!important}
  .card-header,.card-body{padding:0!important;margin:0!important;background:transparent!important;border:none!important;box-shadow:none!important}
  .report-preview{display:block!important;margin:0!important;padding:0!important;width:100%!important}
  .report-preview.print-only{display:block!important}
  .report-preview + .report-preview{page-break-before:always!important}
  /* ── Official CSPC Letterhead Header ── */
  .report-header-block{display:block!important;width:100%!important;border-bottom:2.5pt solid #000!important;padding:0 0 0.3cm 0!important;margin:0 0 0.4cm 0!important;position:relative!important;overflow:visible!important}
  .report-header-block::before{content:'CSPC-F-STA-01';display:block!important;font-size:7pt!important;font-weight:700!important;text-align:right!important;position:absolute!important;top:0!important;right:0!important;font-family:'Arial',sans-serif!important}
  .report-header-block > *{display:none!important}
  .report-header-block > .print-header-inner{display:flex!important;align-items:center!important;gap:0.4cm!important;padding-top:0.2cm!important}
  .report-header-block > .print-header-inner > img{width:1.4cm!important;height:1.4cm!important;object-fit:contain!important;flex-shrink:0!important;display:block!important}
  .report-header-block > .print-header-inner > .print-header-text{flex:1!important;text-align:center!important;display:block!important}
  .print-header-inner .ph-republic{display:block!important;font-size:7.5pt!important;font-weight:400!important;font-style:italic!important;text-align:center!important;margin:0!important;line-height:1.4!important}
  .print-header-inner .ph-institution{display:block!important;font-size:13pt!important;font-weight:900!important;text-transform:uppercase!important;text-align:center!important;letter-spacing:0.03em!important;margin:0.04cm 0 0!important;line-height:1.2!important}
  .print-header-inner .ph-address{display:block!important;font-size:8pt!important;text-align:center!important;margin:0.02cm 0 0.12cm!important;line-height:1.3!important}
  .print-header-inner .ph-title{display:block!important;font-size:13pt!important;font-weight:800!important;text-transform:uppercase!important;text-align:center!important;text-decoration:underline!important;letter-spacing:0.04em!important;margin:0.12cm 0 0.04cm!important;line-height:1.2!important}
  .print-header-inner .ph-subtitle{display:block!important;font-size:9pt!important;font-weight:600!important;text-align:center!important;margin:0 0 0.04cm!important}
  .print-header-inner .ph-period{display:block!important;font-size:8pt!important;text-align:center!important;margin:0.04cm 0 0!important;color:#333!important}
  /* ── Table ── */
  div[style*="padding:0 1.5rem"]{padding:0!important}
  div[style*="overflow-x:auto"]{overflow:visible!important}
  .pagination-bar,button{display:none!important}
  .data-table{margin:0!important;padding:0!important;width:100%!important;border-collapse:collapse!important;font-family:'Arial',sans-serif!important;font-size:8.5pt!important}
  .data-table th{background:#e8e8e8!important;border:1pt solid #000!important;padding:0.18cm 0.2cm!important;font-weight:700!important;text-align:left!important;vertical-align:middle!important}
  .data-table td{border:1pt solid #000!important;padding:0.15cm 0.2cm!important;text-align:left!important;vertical-align:top!important}
  .data-table tr:nth-child(even) td{background:#f5f5f5!important}
  .table-badge{background:none!important;border:none!important;padding:0!important;font-weight:700!important;font-size:8pt!important;color:#000!important}
  .apt-avatar-xs{display:none!important}
  .section-divider{border-top:1px solid #000!important;margin:0.3cm 0!important}
}
</style>
<div class="instructor-layout">
  <%- include('../../partials/dean-sidebar', { activePage: 'reports' }) %>
  <main class="instructor-main">
    <div class="main-container">
      <div class="page-header">
        <div>
          <h1 class="page-title">Reports</h1>
          <p class="page-subtitle">Department consultation appointments, student records, and faculty workload analysis</p>
        </div>
      </div>

      <!-- Stat cards -->
      <div class="stats-overview">
        <div class="stat-card-large presence">
          <div class="stat-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
          <div class="stat-card-content">
            <p class="stat-card-label">Total Appointments</p>
            <h2 class="stat-card-value" id="statTotal"><%= allAppointments.length %></h2>
            <p class="stat-card-sublabel" id="statTotalSub">All records</p>
          </div>
        </div>
        <div class="stat-card-large confirmed">
          <div class="stat-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
          <div class="stat-card-content">
            <p class="stat-card-label">Confirmed</p>
            <h2 class="stat-card-value" id="statConfirmed"><%= allAppointments.filter(function(a){return a.status==='confirmed';}).length %></h2>
            <p class="stat-card-sublabel">Completed</p>
          </div>
        </div>
        <div class="stat-card-large pending">
          <div class="stat-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg></div>
          <div class="stat-card-content">
            <p class="stat-card-label">Declined</p>
            <h2 class="stat-card-value" id="statDeclined"><%= allAppointments.filter(function(a){return a.status==='declined';}).length %></h2>
            <p class="stat-card-sublabel">Rejected</p>
          </div>
        </div>
        <div class="stat-card-large workload">
          <div class="stat-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
          <div class="stat-card-content">
            <p class="stat-card-label">Faculty Count</p>
            <h2 class="stat-card-value" id="statFaculty"><%= faculty.length %></h2>
            <p class="stat-card-sublabel" id="statFacultySub">In department</p>
          </div>
        </div>
      </div>

      <!-- Analytics grid -->
      <div class="analytics-grid">
        <div class="content-card">
          <div class="card-header">
            <h3 class="card-title">Appointment Activity</h3>
            <span style="font-size:.75rem;color:var(--gray-400)">Mon-Fri this week</span>
          </div>
          <div class="card-body">
            <div class="bar-chart" id="activityChart">
              <%
                var days = ['Mon','Tue','Wed','Thu','Fri'];
                var dayCounts = [0,0,0,0,0];
                allAppointments.forEach(function(a){
                  var d = new Date(a.date);
                  var dow = d.getDay();
                  if(dow>=1&&dow<=5) dayCounts[dow-1]++;
                });
                var maxDay = 1;
                for(var di=0;di<dayCounts.length;di++){ if(dayCounts[di]>maxDay) maxDay=dayCounts[di]; }
              %>
              <% for(var di2=0;di2<days.length;di2++){ %>
              <%   var pct = Math.round((dayCounts[di2]/maxDay)*100); %>
              <div class="bar-chart-item">
                <div class="bar-chart-bar-wrap">
                  <div class="bar-chart-bar" style="height:<%= pct %>%" title="<%= dayCounts[di2] %> appointments">
                    <% if(pct>=30){ %><span class="bar-value"><%= dayCounts[di2] %></span><% } %>
                  </div>
                </div>
                <span class="bar-label"><%= days[di2] %></span>
              </div>
              <% } %>
            </div>
            <p class="chart-legend">Appointments per day (all time)</p>
          </div>
        </div>
        <div class="content-card">
          <div class="card-header">
            <h3 class="card-title">Appointment Breakdown</h3>
            <span id="breakdownPeriodLabel" style="font-size:.75rem;color:var(--gray-400)">This Week</span>
          </div>
          <div class="card-body">
            <%
              var bdTot  = allAppointments.length || 1;
              var bdConf = allAppointments.filter(function(a){return a.status==='confirmed';}).length;
              var bdDecl = allAppointments.filter(function(a){return a.status==='declined';}).length;
              var bdPend = allAppointments.filter(function(a){return a.status==='pending';}).length;
            %>
            <div class="workload-breakdown" id="breakdownList">
              <div class="breakdown-row">
                <span class="breakdown-label"><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#16a34a;margin-right:.4rem;vertical-align:middle"></span>Confirmed</span>
                <div class="breakdown-bar-wrap"><div class="breakdown-bar confirmed" style="width:<%= Math.round(bdConf/bdTot*100) %>%"></div></div>
                <span class="breakdown-value"><%= bdConf %></span>
              </div>
              <div class="breakdown-row">
                <span class="breakdown-label"><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#dc2626;margin-right:.4rem;vertical-align:middle"></span>Declined</span>
                <div class="breakdown-bar-wrap"><div class="breakdown-bar" style="width:<%= Math.round(bdDecl/bdTot*100) %>%;background:linear-gradient(90deg,#dc2626,#ef4444)"></div></div>
                <span class="breakdown-value"><%= bdDecl %></span>
              </div>
              <div class="breakdown-row">
                <span class="breakdown-label"><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#ea580c;margin-right:.4rem;vertical-align:middle"></span>Pending</span>
                <div class="breakdown-bar-wrap"><div class="breakdown-bar" style="width:<%= Math.round(bdPend/bdTot*100) %>%;background:linear-gradient(90deg,#ea580c,#fb923c)"></div></div>
                <span class="breakdown-value"><%= bdPend %></span>
              </div>
            </div>
            <div style="display:flex;gap:.75rem;margin-top:1.5rem;padding-top:1rem;border-top:1px solid var(--gray-100)">
              <div style="flex:1;text-align:center;padding:.625rem;background:rgba(22,163,74,.06);border-radius:8px">
                <p style="font-size:1.125rem;font-weight:800;color:#15803d;margin:0" id="miniWeek"><%= allAppointments.filter(function(a){return a.status==='confirmed';}).length %></p>
                <p style="font-size:.65rem;color:var(--gray-500);text-transform:uppercase;letter-spacing:.04em;margin:2px 0 0">Confirmed</p>
              </div>
              <div style="flex:1;text-align:center;padding:.625rem;background:rgba(10,61,98,.06);border-radius:8px">
                <p style="font-size:1.125rem;font-weight:800;color:var(--primary-blue);margin:0" id="miniMonth"><%= faculty.length %></p>
                <p style="font-size:.65rem;color:var(--gray-500);text-transform:uppercase;letter-spacing:.04em;margin:2px 0 0">Faculty</p>
              </div>
              <div style="flex:1;text-align:center;padding:.625rem;background:rgba(124,58,237,.06);border-radius:8px">
                <p style="font-size:1.125rem;font-weight:800;color:#7c3aed;margin:0" id="miniHours"><%= faculty.reduce(function(s,f){return s+f.hoursThisMonth;},0) %>h</p>
                <p style="font-size:.65rem;color:var(--gray-500);text-transform:uppercase;letter-spacing:.04em;margin:2px 0 0">Total Hrs</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Appointments Report -->
      <div class="content-card" style="margin-top:1.5rem;overflow:visible">
        <div class="card-body">
          <div class="report-preview">
            <div class="report-header-block" style="display:flex;align-items:flex-start;gap:1rem;padding:1.25rem 1.5rem;border-bottom:3px solid #1a1a1a;position:relative">
              <img src="/images/CSPC-logo.png" alt="CSPC" style="width:64px;height:64px;object-fit:contain;flex-shrink:0" onerror="this.style.display='none'">
              <div>
                <p class="report-republic">Republic of the Philippines</p>
                <p class="report-institution">Camarines Sur Polytechnic Colleges</p>
                <p class="report-college">College of Computer Studies</p>
                <h4 class="report-title-block">Appointments Report</h4>
                <p class="report-subtitle">Department Consultation Appointments</p>
                <p class="report-period">Dean: <strong><%= dean.name %></strong> &middot; Period: <span id="appointmentsReportPeriodText">All Records</span></p>
              </div>
              <div style="margin-left:auto">
                <button class="btn-header-action primary" id="btnExportAppointments" style="height:36px;padding:0 1rem;font-size:.75rem;display:flex;align-items:center;gap:.4rem" onclick="preparePrintReport(this)">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                  Export/Print
                </button>
              </div>
            </div>

            <%- include('../../partials/filter-bar', {
              filterId: 'appointments',
              searchPlaceholder: 'Search student or topic…',
              filterSections: [
                { label: 'By Date', key: 'period', type: 'buttons',
                  items: [{ value:'all', label:'All' }, { value:'week', label:'This Week' }, { value:'month', label:'This Month' }] },
                { label: 'Specific Day', type: 'date' },
                { label: 'By Status', key: 'status', type: 'buttons',
                  items: [{ value:'all', label:'All Status' }, { value:'confirmed', label:'Confirmed' },
                          { value:'pending', label:'Pending' }, { value:'declined', label:'Declined' }] },
                { label: 'By Faculty', key: 'faculty', type: 'buttons',
                  items: [{ value:'all', label:'All Faculty' }].concat(faculty.map(function(f){ return { value: f.name, label: f.name }; })) }
              ]
            }) %>

            <div style="padding:0 1.5rem 1.5rem">
              <div style="overflow-x:auto;margin-top:1rem">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th>Student</th>
                      <th>Faculty</th>
                      <th>Date</th>
                      <th>Time</th>
                      <th>Topic</th>
                      <th>Status</th>
                      <th>Duration</th>
                    </tr>
                  </thead>
                  <tbody id="appointmentsReportBody"></tbody>
                </table>
              </div>
              <div class="pagination-bar" id="appointmentsReportPagBar">
                <span class="page-info" id="appointmentsReportPageInfo">-</span>
                <div class="pagination-controls">
                  <button class="btn-page" id="appointmentsReportPrev" disabled>Prev</button>
                  <button class="btn-page" id="appointmentsReportNext" disabled>Next</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Student Appointment Logs Report -->
      <div class="content-card" style="margin-top:1.5rem;overflow:visible">
        <div class="card-body">
          <div class="report-preview">
            <div class="report-header-block" style="display:flex;align-items:flex-start;gap:1rem;padding:1.25rem 1.5rem;border-bottom:3px solid #1a1a1a;position:relative">
              <img src="/images/CSPC-logo.png" alt="CSPC" style="width:64px;height:64px;object-fit:contain;flex-shrink:0" onerror="this.style.display='none'">
              <div>
                <p class="report-republic">Republic of the Philippines</p>
                <p class="report-institution">Camarines Sur Polytechnic Colleges</p>
                <p class="report-college">College of Computer Studies</p>
                <h4 class="report-title-block">Student Appointment Logs Report</h4>
                <p class="report-subtitle">Student Consultation Activity Records</p>
                <p class="report-period">Dean: <strong><%= dean.name %></strong> &middot; Period: <span id="salReportPeriodText">All Records</span></p>
              </div>
              <div style="margin-left:auto">
                <button class="btn-header-action primary" id="btnExportSal" style="height:36px;padding:0 1rem;font-size:.75rem;display:flex;align-items:center;gap:.4rem" onclick="preparePrintReport(this)">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                  Export/Print
                </button>
              </div>
            </div>

            <%- include('../../partials/filter-bar', {
              filterId: 'sal',
              searchPlaceholder: 'Search student or topic…',
              filterSections: [
                { label: 'By Date', key: 'period', type: 'buttons',
                  items: [{ value:'all', label:'All' }, { value:'week', label:'This Week' }, { value:'month', label:'This Month' }] },
                { label: 'Specific Day', type: 'date' },
                { label: 'By Status', key: 'status', type: 'buttons',
                  items: [{ value:'all', label:'All Status' }, { value:'confirmed', label:'Confirmed' },
                          { value:'pending', label:'Pending' }, { value:'declined', label:'Declined' }] }
              ]
            }) %>

            <div style="padding:0 1.5rem 1.5rem">
              <div style="overflow-x:auto;margin-top:1rem">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th>Student</th>
                      <th>Faculty</th>
                      <th>Date</th>
                      <th>Time</th>
                      <th>Topic</th>
                      <th>Status</th>
                      <th style="text-align:center">Details</th>
                    </tr>
                  </thead>
                  <tbody id="salReportBody"></tbody>
                </table>
              </div>
              <div class="pagination-bar" id="salReportPagBar">
                <span class="page-info" id="salReportPageInfo">-</span>
                <div class="pagination-controls">
                  <button class="btn-page" id="salReportPrev" disabled>Prev</button>
                  <button class="btn-page" id="salReportNext" disabled>Next</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Faculty Consultation Workload Report -->
      <div class="content-card" style="margin-top:1.5rem;overflow:visible">
        <div class="card-body">
          <div class="report-preview">
            <div class="report-header-block" style="display:flex;align-items:flex-start;gap:1rem;padding:1.25rem 1.5rem;border-bottom:3px solid #1a1a1a;position:relative">
              <img src="/images/CSPC-logo.png" alt="CSPC" style="width:64px;height:64px;object-fit:contain;flex-shrink:0" onerror="this.style.display='none'">
              <div>
                <p class="report-republic">Republic of the Philippines</p>
                <p class="report-institution">Camarines Sur Polytechnic Colleges</p>
                <p class="report-college">College of Computer Studies</p>
                <h4 class="report-title-block">Faculty Consultation Workload Report</h4>
                <p class="report-subtitle">Faculty Performance and Workload Analysis</p>
                <p class="report-period">Dean: <strong><%= dean.name %></strong> &middot; Period: <span id="fcwReportPeriodText">All Records</span></p>
              </div>
              <div style="margin-left:auto">
                <button class="btn-header-action primary" id="btnExportFcw" style="height:36px;padding:0 1rem;font-size:.75rem;display:flex;align-items:center;gap:.4rem" onclick="preparePrintReport(this)">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                  Export/Print
                </button>
              </div>
            </div>

            <%- include('../../partials/filter-bar', {
              filterId: 'fcw',
              searchPlaceholder: 'Search faculty or room…',
              filterSections: [
                { label: 'By Date', key: 'period', type: 'buttons',
                  items: [{ value:'all', label:'All' }, { value:'week', label:'This Week' }, { value:'month', label:'This Month' }] },
                { label: 'By Faculty', key: 'faculty', type: 'buttons',
                  items: [{ value:'all', label:'All Faculty' }].concat(faculty.map(function(f){ return { value: f.name, label: f.name }; })) }
              ]
            }) %>

            <div style="padding:0 1.5rem 1.5rem">
              <div style="overflow-x:auto;margin-top:1rem">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th>Faculty Name</th>
                      <th>Office Room</th>
                      <th style="text-align:center">Total Hours</th>
                      <th style="text-align:center">Consultations</th>
                      <th style="text-align:center">Avg Duration</th>
                      <th>Status</th>
                    </tr>
                  </thead>
                  <tbody id="fcwReportBody"></tbody>
                </table>
              </div>
              <div class="pagination-bar" id="fcwReportPagBar">
                <span class="page-info" id="fcwReportPageInfo">-</span>
                <div class="pagination-controls">
                  <button class="btn-page" id="fcwReportPrev" disabled>Prev</button>
                  <button class="btn-page" id="fcwReportNext" disabled>Next</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>
</div>
<div class="toast-container" id="toastContainer"></div>
<%- include('../../partials/footer') %>
<%- include('../../partials/script') %>

<script>
(function(){
  var ALL = <%- JSON.stringify(allAppointments) %>;
  var FACULTY = <%- JSON.stringify(faculty) %>;
  var period = 'all', facultyFilter = 'all', PAGE = 10;

  function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
  function parseDate(v){ var d = new Date(v); return isNaN(d.getTime()) ? null : d; }
  function formatDate(v){ var d = parseDate(v); return d ? d.toLocaleDateString('en-PH', { month:'long', day:'numeric', year:'numeric' }) : '—'; }

  function weekRange(){
    var d=new Date(), s=new Date(d);
    s.setDate(d.getDate()-d.getDay());
    var e=new Date(s); e.setDate(s.getDate()+6);
    return {s:s, e:e};
  }
  function monthRange(){
    var d=new Date();
    return {s:new Date(d.getFullYear(),d.getMonth(),1), e:new Date(d.getFullYear(),d.getMonth()+1,0)};
  }

  function filter(){
    var rows = ALL;
    // Faculty filter
    if(facultyFilter !== 'all') rows = rows.filter(function(a){ return a.instructorName === facultyFilter; });
    // Period filter
    if(period === 'week'){
      var r=weekRange();
      rows = rows.filter(function(a){ var d=new Date(a.date); return d>=r.s&&d<=r.e; });
    } else if(period === 'month'){
      var r2=monthRange();
      rows = rows.filter(function(a){ var d=new Date(a.date); return d>=r2.s&&d<=r2.e; });
    } else if(period === 'custom' && customDate){
      var t=new Date(customDate);
      rows = rows.filter(function(a){ return new Date(a.date).toDateString()===t.toDateString(); });
    }
    return rows;
  }

  function lbl(){ return {week:'This Week',month:'This Month',all:'All Time',custom:customDate||'Custom Date'}[period]||''; }

  function updateStats(rows){
    var conf=rows.filter(function(a){return a.status==='confirmed';}).length;
    var decl=rows.filter(function(a){return a.status==='declined';}).length;
    var pend=rows.filter(function(a){return a.status==='pending';}).length;
    var tot=rows.length||1;
    document.getElementById('statTotal').textContent = rows.length;
    document.getElementById('statTotalSub').textContent = rows.length===ALL.length ? 'All records' : 'In period';
    document.getElementById('statConfirmed').textContent = conf;
    document.getElementById('statDeclined').textContent = decl;
    // Faculty count
    var activeFaculty = facultyFilter==='all' ? FACULTY.length : 1;
    document.getElementById('statFaculty').textContent = activeFaculty;
    document.getElementById('statFacultySub').textContent = facultyFilter==='all' ? 'In department' : 'Selected';
    // Breakdown bars
    var brows = document.querySelectorAll('#breakdownList .breakdown-row');
    if(brows.length>=3){
      [[0,conf,'confirmed'],[1,decl,'declined'],[2,pend,'pending']].forEach(function(pair){
        brows[pair[0]].querySelector('.breakdown-bar').style.width = Math.round(pair[1]/tot*100)+'%';
        brows[pair[0]].querySelector('.breakdown-value').textContent = pair[1];
      });
    }
    document.getElementById('miniWeek').textContent = conf;
    // Total hours for selected faculty
    var hrs = facultyFilter==='all'
      ? FACULTY.reduce(function(s,f){return s+f.hoursThisMonth;},0)
      : (FACULTY.find(function(f){return f.name===facultyFilter;})||{hoursThisMonth:0}).hoursThisMonth;
    document.getElementById('miniHours').textContent = hrs+'h';
    document.getElementById('miniMonth').textContent = activeFaculty;
  }

  function apply(){
    var l=lbl(), rows=filter();
    ['breakdownPeriodLabel'].forEach(function(id){
      var el=document.getElementById(id); if(el) el.textContent=l;
    });
    updateStats(rows);
  }

  // ===== Student Appointment Logs Report =====
  var salPage = 1, salPeriod = 'all', salStatus = 'all';
  var salBody = document.getElementById('salReportBody');
  var salPagBar = document.getElementById('salReportPagBar');
  var salPageInfo = document.getElementById('salReportPageInfo');

  function filterSalRows(){
    var rows = ALL.slice();
    if(salPeriod === 'week'){
      var r=weekRange();
      rows = rows.filter(function(a){ var d=new Date(a.date); return d>=r.s&&d<=r.e; });
    } else if(salPeriod === 'month'){
      var r2=monthRange();
      rows = rows.filter(function(a){ var d=new Date(a.date); return d>=r2.s&&d<=r2.e; });
    }
    if(salStatus !== 'all') rows = rows.filter(function(a){ return a.status===salStatus; });
    return rows;
  }

  function renderSalTable(rows){
    var total=rows.length, pages=Math.max(1,Math.ceil(total/PAGE));
    if(salPage>pages) salPage=pages;
    var s=(salPage-1)*PAGE, slice=rows.slice(s,s+PAGE);
    salBody.innerHTML='';
    if(!slice.length){
      salBody.innerHTML='<tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--gray-400)">No appointments found.</td></tr>';
    } else {
      slice.forEach(function(a){
        var sc=a.status.charAt(0).toUpperCase()+a.status.slice(1);
        var tr=document.createElement('tr');
        tr.innerHTML='<td><div><p style="font-weight:600;font-size:.875rem;color:var(--gray-900);margin:0">'+esc(a.studentName)+'</p><p style="font-size:.6875rem;color:var(--gray-400);margin:0">'+esc(a.studentId)+'</p></div></td>'
          +'<td style="font-size:.8125rem;color:var(--gray-700)">'+esc(a.instructorName)+'</td>'
          +'<td style="white-space:nowrap">'+esc(formatDate(a.date))+'</td>'
          +'<td style="white-space:nowrap">'+esc(a.time)+'</td>'
          +'<td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="'+esc(a.topic)+'">'+esc(a.topic)+'</td>'
          +'<td><span class="table-badge '+a.status+'">'+sc+'</span></td>'
          +'<td style="text-align:center"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></td>';
        salBody.appendChild(tr);
      });
    }
    salPageInfo.textContent = total ? ('Showing '+(s+1)+'-'+Math.min(s+PAGE,total)+' of '+total) : 'No results';
    document.getElementById('salReportPrev').disabled = salPage<=1;
    document.getElementById('salReportNext').disabled = salPage>=pages;
  }

  // ===== Faculty Consultation Workload Report =====
  var fcwPage = 1, fcwPeriod = 'all', fcwFaculty = 'all';
  var fcwBody = document.getElementById('fcwReportBody');
  var fcwPageInfo = document.getElementById('fcwReportPageInfo');

  function filterFcwRows(){
    var rows = FACULTY.slice();
    if(fcwFaculty !== 'all') rows = rows.filter(function(f){ return f.name===fcwFaculty; });
    return rows;
  }

  function renderFcwTable(rows){
    var total=rows.length, pages=Math.max(1,Math.ceil(total/PAGE));
    if(fcwPage>pages) fcwPage=pages;
    var s=(fcwPage-1)*PAGE, slice=rows.slice(s,s+PAGE);
    fcwBody.innerHTML='';
    if(!slice.length){
      fcwBody.innerHTML='<tr><td colspan="6" style="text-align:center;padding:2rem;color:var(--gray-400)">No faculty found.</td></tr>';
    } else {
      slice.forEach(function(f){
        var tr=document.createElement('tr');
        var badgeClass = f.bleStatus==='in-room' ? 'confirmed' : 'declined';
        var badgeText = f.bleStatus==='in-room' ? 'In Room' : 'Out';
        tr.innerHTML='<td><strong>'+esc(f.name)+'</strong></td>'
          +'<td>'+esc(f.officeRoom)+'</td>'
          +'<td style="text-align:center">'+esc(f.hoursThisMonth)+'h</td>'
          +'<td style="text-align:center">'+esc(f.consultationsThisMonth)+'</td>'
          +'<td style="text-align:center">'+esc(f.avgDuration)+'</td>'
          +'<td><span class="table-badge '+badgeClass+'">'+badgeText+'</span></td>';
        fcwBody.appendChild(tr);
      });
    }
    fcwPageInfo.textContent = total ? ('Showing '+(s+1)+'-'+Math.min(s+PAGE,total)+' of '+total) : 'No results';
    document.getElementById('fcwReportPrev').disabled = fcwPage<=1;
    document.getElementById('fcwReportNext').disabled = fcwPage>=pages;
  }

  // Filter bar handlers for Student Appointment Logs Report
  document.querySelectorAll('[data-filterid="sal"]').forEach(function(item){
    var filterBar = item.closest('[data-filter-bar-id]') || item.parentElement;
    if(item.dataset.group){
      item.addEventListener('click', function(){
        if(item.dataset.group==='period'){ salPeriod=item.dataset.value||'all'; salPage=1; }
        else if(item.dataset.group==='status'){ salStatus=item.dataset.value||'all'; salPage=1; }
        renderSalTable(filterSalRows());
        document.getElementById('salReportPeriodText').textContent = {all:'All Records',week:'This Week',month:'This Month',custom:'Custom Date'}[salPeriod]||'All Records';
      });
    }
  });

  // Pagination for Student Appointment Logs Report
  document.getElementById('salReportPrev').addEventListener('click', function(){
    if(salPage>1){ salPage--; renderSalTable(filterSalRows()); }
  });
  document.getElementById('salReportNext').addEventListener('click', function(){
    var r=filterSalRows(), pages=Math.ceil(r.length/PAGE);
    if(salPage<pages){ salPage++; renderSalTable(r); }
  });

  // Filter bar handlers for Faculty Consultation Workload Report
  document.querySelectorAll('[data-filterid="fcw"]').forEach(function(item){
    if(item.dataset.group){
      item.addEventListener('click', function(){
        if(item.dataset.group==='period'){ fcwPeriod=item.dataset.value||'all'; fcwPage=1; }
        else if(item.dataset.group==='faculty'){ fcwFaculty=item.dataset.value||'all'; fcwPage=1; }
        renderFcwTable(filterFcwRows());
        document.getElementById('fcwReportPeriodText').textContent = {all:'All Records',week:'This Week',month:'This Month',custom:'Custom Date'}[fcwPeriod]||'All Records';
      });
    }
  });

  // Pagination for Faculty Consultation Workload Report
  document.getElementById('fcwReportPrev').addEventListener('click', function(){
    if(fcwPage>1){ fcwPage--; renderFcwTable(filterFcwRows()); }
  });
  document.getElementById('fcwReportNext').addEventListener('click', function(){
    var r=filterFcwRows(), pages=Math.ceil(r.length/PAGE);
    if(fcwPage<pages){ fcwPage++; renderFcwTable(r); }
  });

  // ===== Appointments Report =====
  var appointmentsReportPage = 1, appointmentsReportPeriod = 'all', appointmentsReportStatus = 'all', appointmentsReportFaculty = 'all';
  var appointmentsReportBody = document.getElementById('appointmentsReportBody');
  var appointmentsReportPageInfo = document.getElementById('appointmentsReportPageInfo');

  function filterAppointmentsReportRows(){
    var rows = ALL.slice();
    if(appointmentsReportPeriod === 'week'){
      var r=weekRange();
      rows = rows.filter(function(a){ var d=new Date(a.date); return d>=r.s&&d<=r.e; });
    } else if(appointmentsReportPeriod === 'month'){
      var r2=monthRange();
      rows = rows.filter(function(a){ var d=new Date(a.date); return d>=r2.s&&d<=r2.e; });
    }
    if(appointmentsReportStatus !== 'all') rows = rows.filter(function(a){ return a.status===appointmentsReportStatus; });
    if(appointmentsReportFaculty !== 'all') rows = rows.filter(function(a){ return a.instructorName===appointmentsReportFaculty; });
    return rows;
  }

  function renderAppointmentsReportTable(rows){
    var total=rows.length, pages=Math.max(1,Math.ceil(total/PAGE));
    if(appointmentsReportPage>pages) appointmentsReportPage=pages;
    var s=(appointmentsReportPage-1)*PAGE, slice=rows.slice(s,s+PAGE);
    appointmentsReportBody.innerHTML='';
    if(!slice.length){
      appointmentsReportBody.innerHTML='<tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--gray-400)">No appointments found.</td></tr>';
    } else {
      slice.forEach(function(a){
        var sc=a.status.charAt(0).toUpperCase()+a.status.slice(1);
        var tr=document.createElement('tr');
        tr.innerHTML='<td><div><p style="font-weight:600;font-size:.875rem;color:var(--gray-900);margin:0">'+esc(a.studentName)+'</p><p style="font-size:.6875rem;color:var(--gray-400);margin:0">'+esc(a.studentId)+'</p></div></td>'
          +'<td style="font-size:.8125rem;color:var(--gray-700)">'+esc(a.instructorName)+'</td>'
          +'<td style="white-space:nowrap">'+esc(formatDate(a.date))+'</td>'
          +'<td style="white-space:nowrap">'+esc(a.time)+'</td>'
          +'<td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="'+esc(a.topic)+'">'+esc(a.topic)+'</td>'
          +'<td><span class="table-badge '+a.status+'">'+sc+'</span></td>'
          +'<td>'+esc(a.duration)+'</td>';
        appointmentsReportBody.appendChild(tr);
      });
    }
    appointmentsReportPageInfo.textContent = total ? ('Showing '+(s+1)+'-'+Math.min(s+PAGE,total)+' of '+total) : 'No results';
    document.getElementById('appointmentsReportPrev').disabled = appointmentsReportPage<=1;
    document.getElementById('appointmentsReportNext').disabled = appointmentsReportPage>=pages;
  }

  // Filter bar handlers for Appointments Report
  document.querySelectorAll('[data-filterid="appointments"]').forEach(function(item){
    var filterBar = item.closest('[data-filter-bar-id]') || item.parentElement;
    if(item.dataset.group){
      item.addEventListener('click', function(){
        if(item.dataset.group==='period'){ appointmentsReportPeriod=item.dataset.value||'all'; appointmentsReportPage=1; }
        else if(item.dataset.group==='status'){ appointmentsReportStatus=item.dataset.value||'all'; appointmentsReportPage=1; }
        else if(item.dataset.group==='faculty'){ appointmentsReportFaculty=item.dataset.value||'all'; appointmentsReportPage=1; }
        renderAppointmentsReportTable(filterAppointmentsReportRows());
        document.getElementById('appointmentsReportPeriodText').textContent = {all:'All Records',week:'This Week',month:'This Month',custom:'Custom Date'}[appointmentsReportPeriod]||'All Records';
      });
    }
  });

  // Pagination for Appointments Report
  document.getElementById('appointmentsReportPrev').addEventListener('click', function(){
    if(appointmentsReportPage>1){ appointmentsReportPage--; renderAppointmentsReportTable(filterAppointmentsReportRows()); }
  });
  document.getElementById('appointmentsReportNext').addEventListener('click', function(){
    var r=filterAppointmentsReportRows(), pages=Math.ceil(r.length/PAGE);
    if(appointmentsReportPage<pages){ appointmentsReportPage++; renderAppointmentsReportTable(r); }
  });

  // Initial render
  renderSalTable(filterSalRows());
  renderFcwTable(filterFcwRows());
  renderAppointmentsReportTable(filterAppointmentsReportRows());
  apply();
}());

function preparePrintReport(item){
  var preview = item.closest('.report-preview');
  if(!preview) return;
  preview.querySelectorAll('.report-header-block').forEach(function(hdr){
    var existing = hdr.querySelector('.print-header-inner');
    if(existing) existing.remove();
    var titleEl    = hdr.querySelector('.report-title-block');
    var subtitleEl = hdr.querySelector('.report-subtitle');
    var periodEl   = hdr.querySelector('.report-period');
    var imgEl      = hdr.querySelector('img');
    var title    = titleEl    ? titleEl.textContent.trim()    : '';
    var subtitle = subtitleEl ? subtitleEl.textContent.trim() : '';
    var period   = periodEl   ? periodEl.innerText.trim()     : '';
    var imgSrc   = imgEl      ? imgEl.src                     : '/images/CSPC-logo.png';
    var inner = document.createElement('div');
    inner.className = 'print-header-inner';
    inner.innerHTML =
      '<img src="'+imgSrc+'" alt="CSPC Logo">' +
      '<div class="print-header-text">' +
        '<span class="ph-republic">Republic of the Philippines</span>' +
        '<span class="ph-institution">Camarines Sur Polytechnic Colleges</span>' +
        '<span class="ph-address">Nabua, Camarines Sur</span>' +
        '<span class="ph-title">'+title+'</span>' +
        '<span class="ph-subtitle">'+subtitle+'</span>' +
        (period ? '<span class="ph-period">'+period+'</span>' : '') +
      '</div>';
    hdr.appendChild(inner);
  });
  document.querySelectorAll('.report-preview.print-only').forEach(function(c){ c.classList.remove('print-only'); });
  preview.classList.add('print-only');
  document.body.classList.add('print-mode');
  setTimeout(function(){
    window.print();
    setTimeout(function(){
      preview.classList.remove('print-only');
      document.body.classList.remove('print-mode');
      preview.querySelectorAll('.print-header-inner').forEach(function(el){ el.remove(); });
    }, 500);
  }, 50);
}
</script>
