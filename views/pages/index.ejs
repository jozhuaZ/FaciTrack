<%- include('../partials/header') %>
  <link rel="stylesheet" href="/css/index.css?v=<%= Date.now() %>">
  <link rel="stylesheet" href="/css/login.css?v=<%= Date.now() %>">


  <!-- Landing page nav override -->
  <script>
    document.querySelector('.main-header').classList.add('landing-header');
    document.querySelector('.header-institution').style.display = 'none';

    // Anchor scroll offset
    ['hero-section', 'student-section', 'about-section'].forEach(function (cls) {
      var el = document.querySelector('.' + cls);
      if (el) {
        el.style.scrollMarginTop = '64px';
      }
    });
  </script>

  <!-- Inject landing nav into header -->
  <script>
    (function () {
      var hc = document.querySelector('.header-container');

      // Hamburger toggle button (mobile only)
      var toggle = document.createElement('button');
      toggle.className = 'landing-nav-toggle';
      toggle.setAttribute('aria-label', 'Toggle navigation');
      toggle.innerHTML = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>';
      hc.appendChild(toggle);

      var nav = document.createElement('nav');
      nav.className = 'landing-nav';
      nav.innerHTML = '<a href="#top" class="landing-nav-link landing-nav-active">Home</a>'
        + '<a href="#students" class="landing-nav-link">For Students</a>'
        + '<a href="#about" class="landing-nav-link">About</a>'
        + '<a href="/login" style="margin-right: 40px;" class="landing-nav-login">'
        + '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">'
        + '<path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>'
        + '<polyline points="10 17 15 12 10 7"/>'
        + '<line x1="15" y1="12" x2="3" y2="12"/>'
        + '</svg>Login</a>';
      hc.appendChild(nav);

      toggle.addEventListener('click', function () {
        var open = nav.classList.toggle('nav-open');
        toggle.innerHTML = open
          ? '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>'
          : '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>';
      });

      nav.querySelectorAll('a').forEach(function (link) {
        link.addEventListener('click', function () {
          nav.classList.remove('nav-open');
          toggle.innerHTML = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>';
        });
      });
    })();
  </script>

  <main class="landing-main">

    <!-- HERO SECTION -->
    <section class="hero-section" id="top">
      <div class="hero-split">

        <!-- LEFT: branding and image -->
        <div class="hero-left">
          <div class="hero-content">
            <h1 class="hero-title">FaciTrack</h1>
            <p class="hero-subtitle">Faculty Appointment &amp; Real-Time Monitoring System</p>
            <p class="hero-description">
              A smart campus solution for Camarines Sur Polytechnic Colleges that connects students
              with faculty through consultation booking and live presence monitoring.
            </p>
          </div>
          <div class="hero-visual">
            <img class="hero-illustration" src="/images/Gemini_Generated_Image_y03dfy03dfy03dfy.png"
              alt="FaciTrack campus monitoring illustration" />
          </div>
        </div>

        <!-- WAVE DIVIDER -->
        <div class="hero-wave-divider" aria-hidden="true">
          <svg viewBox="0 0 60 900" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M30,0 C10,150 50,300 30,450 C10,600 50,750 30,900"
              stroke="var(--gray-200)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          </svg>
        </div>

        <!-- RIGHT: login card -->
        <div class="hero-right">
          <div class="login-container" style="padding:0;margin:0;width:100%;">
            <div class="login-card">
              <div class="login-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
              </div>
              <div class="login-header">
                <h1 class="login-title">Login</h1>
                <p class="login-description">Sign in with your CSPC credentials</p>
              </div>
              <form action="/login" method="POST" class="login-form">
                <div class="form-group">
                  <label for="email" class="form-label">Email / Username <span class="required">*</span></label>
                  <div class="input-wrapper">
                    <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                      <polyline points="22,6 12,13 2,6"/>
                    </svg>
                    <input type="email" id="email" name="email" class="form-input <%= (error && error !== 'Please enter your password.') ? 'input-error' : '' %>" placeholder="Enter your email" required autofocus>
                  </div>
                  <% if (error && error !== 'Please enter your password.') { %>
                    <span class="field-error">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                      <%= error %>
                    </span>
                  <% } %>
                </div>
                <div class="form-group">
                  <label for="password" class="form-label">Password <span class="required">*</span></label>
                  <div class="input-wrapper">
                    <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                      <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    <input type="password" id="password" name="password" class="form-input <%= (error === 'Please enter your password.') ? 'input-error' : '' %>" placeholder="Enter your password" required>
                  </div>
                  <% if (error === 'Please enter your password.') { %>
                    <span class="field-error">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                      <%= error %>
                    </span>
                  <% } %>
                </div>
                <button type="submit" class="btn-login">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                    <polyline points="10 17 15 12 10 7"/>
                    <line x1="15" y1="12" x2="3" y2="12"/>
                  </svg>
                  Sign In
                </button>
              </form>
              <div class="login-divider">OR</div>
              <p class="login-section-label">Student</p>
              <a href="/auth/google" class="btn-google-login">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
                Sign In with CSPC Email
              </a>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- STUDENT ACCESS SECTION -->
    <section class="student-section" id="students">
      <div class="student-container">
        <div class="student-section-header">
          <h2 class="section-title">Are you a CSPC student?</h2>
          <p class="section-description">
            No login needed. Use your CSPC student email to access faculty schedules,
            check who's available right now, and book a consultation slot.
          </p>
        </div>
        <div class="student-cards">

          <a href="/student/dashboard" class="student-card">
            <div class="student-card-icon">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
              </svg>
            </div>
            <div class="student-card-body">
              <h3 class="student-card-title">Faculty Directory</h3>
              <p class="student-card-desc">Browse all CCS faculty, view their specializations and schedules, and book a
                consultation slot directly from their profile.</p>
            </div>
            <div class="student-card-arrow">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </div>
          </a>

          <a href="/student/appointments" class="student-card">
            <div class="student-card-icon student-card-icon-teal">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
                <path d="M8 14h.01M12 14h.01M8 18h.01M12 18h.01" />
              </svg>
            </div>
            <div class="student-card-body">
              <h3 class="student-card-title">View Appointments</h3>
              <p class="student-card-desc">Check the status of your booked consultations — pending, confirmed, or
                completed.</p>
            </div>
            <div class="student-card-arrow">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </div>
          </a>

          <a href="/student/availability" class="student-card">
            <div class="student-card-icon student-card-icon-green">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
            </div>
            <div class="student-card-body">
              <h3 class="student-card-title">Live Availability</h3>
              <p class="student-card-desc">See which faculty are in their rooms right now — updated in real time via BLE
                detection.</p>
            </div>
            <div class="student-card-arrow">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </div>
          </a>

        </div>
        <p class="student-note">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="16" x2="12" y2="12" />
            <line x1="12" y1="8" x2="12.01" y2="8" />
          </svg>
          Live availability requires a one-time OTP verification using your <strong>@my.cspc.edu.ph</strong> email.
        </p>
      </div>
    </section>

    <!-- ABOUT THE SYSTEM SECTION -->
    <section class="about-section" id="about">
      <div class="about-container">
        <div class="section-header">
          <h2 class="section-title">Everything you need, in one place</h2>
          <p class="section-description">
            From real-time faculty presence to seamless consultation booking —
            FaciTrack keeps the CSPC campus connected.
          </p>
        </div>

        <div class="features-row">
          <!-- Appointment Booking -->
          <div class="feature-item">
            <div class="feature-item-icon feature-icon-blue">
              <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
              </svg>
            </div>
            <div class="feature-item-body">
              <h3 class="feature-title">Appointment Booking</h3>
              <p class="feature-description">
                Easily schedule consultations with faculty by browsing available time slots and booking directly through
                the system.
              </p>
            </div>
          </div>

          <div class="feature-separator-vertical"></div>

          <!-- Real-Time Presence -->
          <div class="feature-item">
            <div class="feature-item-icon feature-icon-teal">
              <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2a10 10 0 0 1 10 10" />
                <path d="M12 2a10 10 0 0 0-10 10" />
                <path d="M2 12a10 10 0 0 0 10 10" />
                <path d="M12 22a10 10 0 0 0 10-10" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            </div>
            <div class="feature-item-body">
              <h3 class="feature-title">Real-Time Presence</h3>
              <p class="feature-description">
                Know instantly whether a faculty member is in their room, so you can plan your visit without wasted
                trips.
              </p>
            </div>
          </div>

          <div class="feature-separator-vertical"></div>

          <!-- Secure OTP Verification -->
          <div class="feature-item">
            <div class="feature-item-icon feature-icon-purple">
              <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                <path d="M9 12l2 2 4-4" />
              </svg>
            </div>
            <div class="feature-item-body">
              <h3 class="feature-title">Secure OTP Verification</h3>
              <p class="feature-description">
                Your identity is verified through a one-time password sent to your school email, keeping access safe and
                trusted.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <%- include('../partials/footer') %>